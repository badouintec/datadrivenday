{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "react",
    "resolveJsonModule": true,
    "types": [
      "astro/client",
      "@cloudflare/workers-types"
    ]
  },
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}

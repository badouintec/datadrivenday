{
  "name": "datadrivenday",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "preview:worker": "npm run build && wrangler dev --config dist/server/wrangler.json",
    "deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 execute datadrivenday --local --file=./db/migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute datadrivenday --remote --file=./db/migrations/0001_initial.sql",
    "sanity": "sanity dev"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.3",
    "@astrojs/react": "^5.0.1",
    "@sanity/astro": "^3.3.1",
    "astro": "^6.0.8",
    "hono": "^4.12.8",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.76.0"
  }
}

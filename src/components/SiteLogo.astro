---
interface Props {
  class?: string;
  title?: string;
}

const { class: className = '', title = 'datadriven.day' } = Astro.props;
---

<img
  src="/logo-datadriven-day.png"
  alt={title}
  class:list={['site-logo', className]}
/>

<style is:global>
  .site-logo {
    display: block;
    height: auto;
    max-width: 100%;
  }
</style>

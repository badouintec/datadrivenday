---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  benchmarkProjects,
  datallerResources,
  datallerStack,
  filteredResources,
  researchResourceGroups,
  strategicStats,
  techComparison,
  thematicAxes,
} from '../data/site';

export const prerender = true;

const staticDashboardData = {
  datallerResources,
  educationalGroups: researchResourceGroups,
  platformLibrary: filteredResources.slice(0, 8),
  benchmarkProjects,
  datallerStack,
  strategicStats,
  techComparison,
  thematicAxes,
};
---

<BaseLayout
  title="Registro | Data Driven Day 2026"
  description="Crea tu cuenta en Data Driven Day y entra a tu tablero personal."
  hideFooter={true}
>
  <link slot="head" rel="stylesheet" href="/styles/participant.css" />
  <section class="registro-shell">
    <div id="registroPage" class="page-shell registro-page registro-page--auth-only">
      <div class="registro-grid">
        <div id="authColumn" class="registro-auth-column">
          <div id="authShell" class="registro-auth-card">
            <div class="registro-auth-tabs" role="tablist" aria-label="Acceso a cuenta">
              <button class="registro-tab is-active" type="button" data-auth-tab="signup" role="tab" aria-selected="true" aria-controls="signupPane" id="tab-signup">Crear cuenta</button>
              <button class="registro-tab" type="button" data-auth-tab="login" role="tab" aria-selected="false" aria-controls="loginPane" id="tab-login">Entrar</button>
            </div>

            <form id="signupForm" class="registro-auth-pane is-active" data-auth-pane="signup" id="signupPane" role="tabpanel" aria-labelledby="tab-signup">
              <div class="registro-form-grid">
                <label class="registro-field registro-field--full">
                  <span class="registro-field-label">Nombre completo</span>
                  <input class="registro-input" type="text" name="fullName" placeholder="Tu nombre" required maxlength="120" />
                </label>
                <label class="registro-field registro-field--full">
                  <span class="registro-field-label">Correo</span>
                  <input class="registro-input" type="email" name="email" placeholder="correo@ejemplo.com" required autocomplete="email" />
                </label>
                <label class="registro-field registro-field--full">
                  <span class="registro-field-label">Contraseña</span>
                  <input class="registro-input" type="password" name="password" placeholder="Mínimo 8 caracteres" minlength="8" maxlength="128" required autocomplete="new-password" />
                </label>
              </div>

              <div id="signupStatus" class="registro-status" role="status" aria-live="polite" hidden></div>

              <div class="registro-auth-actions">
                <button class="button" type="submit">Crear cuenta</button>
              </div>
            </form>

            <form id="loginForm" class="registro-auth-pane" data-auth-pane="login" id="loginPane" role="tabpanel" aria-labelledby="tab-login">
              <div class="registro-form-grid registro-form-grid--login">
                <label class="registro-field registro-field--full">
                  <span class="registro-field-label">Correo</span>
                  <input class="registro-input" type="email" name="email" placeholder="correo@ejemplo.com" required autocomplete="email" />
                </label>
                <label class="registro-field registro-field--full">
                  <span class="registro-field-label">Contraseña</span>
                  <input class="registro-input" type="password" name="password" placeholder="Tu contraseña" required autocomplete="current-password" />
                </label>
              </div>

              <div id="loginStatus" class="registro-status" role="status" aria-live="polite" hidden></div>

              <div class="registro-auth-actions registro-auth-actions--col">
                <button class="button" type="submit">Entrar</button>
                <button id="forgotPasswordBtn" class="registro-link-btn" type="button">¿Olvidaste tu contraseña?</button>
              </div>
            </form>
          </div>

          <div id="forgotShell" class="registro-account-card" hidden>
            <p class="registro-account-kicker">Recuperar acceso</p>
            <h2 class="registro-account-title">¿Olvidaste tu contraseña?</h2>
            <p class="registro-account-copy">Escribe tu correo y te mandamos un link para crear una nueva contraseña.</p>
            <form id="forgotForm">
              <label class="registro-field registro-field--full">
                <span class="registro-field-label">Correo registrado</span>
                <input class="registro-input" type="email" name="email" placeholder="correo@ejemplo.com" required autocomplete="email" />
              </label>
              <div id="forgotStatus" class="registro-status" role="status" aria-live="polite" hidden></div>
              <div class="registro-auth-actions registro-auth-actions--tight">
                <button class="button" type="submit">Enviar link</button>
                <button id="forgotBackBtn" class="button-secondary" type="button">Regresar</button>
              </div>
            </form>
          </div>

          <div id="resetShell" class="registro-account-card" hidden>
            <p class="registro-account-kicker">Nueva contraseña</p>
            <h2 class="registro-account-title">Restablece tu contraseña</h2>
            <p class="registro-account-copy">Elige una contraseña de al menos 8 caracteres.</p>
            <form id="resetForm">
              <input type="hidden" name="token" id="resetToken" />
              <label class="registro-field registro-field--full">
                <span class="registro-field-label">Nueva contraseña</span>
                <input class="registro-input" type="password" name="password" placeholder="Mínimo 8 caracteres" minlength="8" maxlength="128" required autocomplete="new-password" />
              </label>
              <div id="resetStatus" class="registro-status" role="status" aria-live="polite" hidden></div>
              <div class="registro-auth-actions">
                <button class="button" type="submit">Guardar contraseña</button>
              </div>
            </form>
          </div>

          <div id="verifyShell" class="registro-account-card" hidden>
            <p class="registro-account-kicker">Verifica tu correo</p>
            <h2 class="registro-account-title">Revisa tu bandeja de entrada</h2>
            <p id="verifyEmail" class="registro-account-copy"></p>
            <p class="registro-account-copy registro-account-copy--subtle">
              Te enviamos un link de verificación. Da click en el link y listo.
            </p>
            <div id="verifyStatus" class="registro-status" role="status" aria-live="polite" hidden></div>
            <div class="registro-auth-actions registro-auth-actions--tight">
              <button id="resendBtn" class="button-secondary" type="button">Reenviar correo</button>
              <a id="verifyDirectLink" class="button-secondary" href="#" hidden>Abrir link de verificación</a>
            </div>
          </div>
        </div>

        <div id="dashboardColumn" class="registro-dashboard-column" hidden>
          <section class="participant-admin-shell">
            <aside class="participant-admin-sidebar">
              <div class="participant-admin-brand">
                <span class="participant-admin-brand-kicker">Data Driven Day</span>
                <strong class="participant-admin-brand-title">Panel participante</strong>
              </div>

              <div class="participant-admin-user-card">
                <div class="participant-admin-user-row">
                  <div id="sidebarAvatar" class="participant-admin-avatar">P</div>
                  <div class="participant-admin-user-info">
                    <p id="sidebarFirstName" class="participant-admin-user-name">Participante</p>
                    <p id="sidebarEmail" class="participant-admin-user-email">correo@ejemplo.com</p>
                  </div>
                </div>
                <div id="sidebarFlags" class="participant-admin-flags"></div>
              </div>

              <nav class="participant-admin-nav" aria-label="Navegacion del tablero participante">
                <button class="participant-admin-nav-link is-active" type="button" data-panel="overviewSection">
                  <svg class="participant-nav-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
                  Resumen
                </button>
                <button class="participant-admin-nav-link" type="button" data-panel="datallerSection">
                  <svg class="participant-nav-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="9,1 3,9 8,9 7,15 13,7 8,7"/></svg>
                  Dataller
                </button>
                <button class="participant-admin-nav-link" type="button" data-panel="resourcesSection">
                  <svg class="participant-nav-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 13.5A1.5 1.5 0 0 1 4.5 12H13"/><path d="M4.5 1H13v14H4.5A1.5 1.5 0 0 1 3 13.5v-11A1.5 1.5 0 0 1 4.5 1z"/></svg>
                  Recursos
                </button>
                <button class="participant-admin-nav-link" type="button" data-panel="communitySection">
                  <svg class="participant-nav-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 14v-1.5a2.5 2.5 0 0 0-2.5-2.5h-5A2.5 2.5 0 0 0 1 12.5V14"/><circle cx="6" cy="5" r="2.5"/><path d="M15 14v-1.34a2.5 2.5 0 0 0-2-2.44"/><path d="M11 2.16a2.5 2.5 0 0 1 0 4.68"/></svg>
                  Comunidad
                </button>
                <button class="participant-admin-nav-link" type="button" data-panel="profileSection">
                  <svg class="participant-nav-icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 14v-1a3 3 0 0 0-3-3H6a3 3 0 0 0-3 3v1"/><circle cx="8" cy="5.5" r="2.5"/></svg>
                  Perfil
                </button>
              </nav>

              <div class="participant-admin-sidebar-footer">
                <button id="logoutBtn" class="button-secondary participant-admin-logout" type="button">Cerrar sesión</button>
              </div>
            </aside>

            <div class="participant-admin-main">
              <header class="participant-admin-topbar">
                <div class="participant-admin-topbar-left">
                  <button id="mobileNavToggle" class="participant-admin-mobile-toggle" type="button" aria-label="Abrir menú" aria-expanded="false">
                    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="1" y1="4" x2="15" y2="4"/><line x1="1" y1="8" x2="15" y2="8"/><line x1="1" y1="12" x2="15" y2="12"/></svg>
                  </button>
                  <div>
                    <p id="topbarKicker" class="participant-admin-kicker">Tablero participante</p>
                    <h2 id="dashboardTitle" class="participant-admin-title">Tu sesión de Data Driven Day</h2>
                  </div>
                </div>
                <div class="participant-admin-badge-row">
                  <span id="dashboardBadge" class="participant-admin-badge">Sin sesión</span>
                  <span id="recognitionBadge" class="participant-admin-badge participant-admin-badge--muted">Reconocimiento pendiente</span>
                </div>
              </header>

              <main class="participant-admin-content">
                <section id="overviewSection" class="participant-admin-section">
                  <div class="participant-admin-section-head">
                    <p class="participant-admin-section-kicker">Empieza aqui</p>
                    <h3 class="participant-admin-section-title">Súmate al Data Driven Day y abre tus materiales</h3>
                  </div>

                  <div class="participant-overview-grid">
                    <article class="participant-panel participant-panel--hero participant-panel--wide">
                      <div class="participant-hero-head">
                        <div>
                          <p class="participant-panel-label">Acceso principal</p>
                          <h3 id="onboardingTitle" class="participant-panel-title">Únete al Dataller para abrir el libro interactivo</h3>
                        </div>
                        <span id="journeyBadge" class="participant-doc-tag">Paso 1</span>
                      </div>
                      <p id="onboardingSummary" class="participant-panel-copy"></p>
                      <div id="onboardingSteps" class="participant-concept-list"></div>
                      <div class="participant-inline-actions">
                        <button id="jumpToDatallerBtn" class="button" type="button">Ir al Dataller</button>
                        <button id="jumpToProfileBtn" class="button-secondary" type="button">Completar perfil</button>
                      </div>
                    </article>

                    <article class="participant-panel participant-panel--recognition">
                      <p class="participant-panel-label">Reconocimiento</p>
                      <h3 class="participant-panel-title">Tu autorización</h3>
                      <div class="participant-lockbox">
                        <span id="recognitionState" class="participant-lock-state">Sin sesión</span>
                        <p id="recognitionCopy">Inicia sesión para ver el estado de tu reconocimiento.</p>
                        <div id="recognitionActions" class="participant-inline-actions participant-recognition-actions" hidden>
                          <a id="recognitionDownload" class="button-secondary" href="/api/participant/recognition" target="_blank" rel="noreferrer">Descargar PDF</a>
                          <span id="recognitionMeta" class="participant-doc-tag"></span>
                        </div>
                      </div>
                    </article>

                    <article class="participant-panel">
                      <p class="participant-panel-label">Notificaciones</p>
                      <h3 class="participant-panel-title">Lo siguiente que te conviene hacer</h3>
                      <div id="notificationList" class="participant-notification-list">
                        <div class="participant-notification-item"><strong>Sin sesión</strong><span>Entra para ver tus pendientes del Dataller.</span></div>
                      </div>
                    </article>

                    <article class="participant-panel">
                      <p class="participant-panel-label">Biblioteca</p>
                      <h3 class="participant-panel-title">Recursos activos en plataforma</h3>
                      <p id="platformSummary" class="participant-panel-copy" hidden></p>
                      <div id="platformResourceList" class="participant-doc-list"></div>
                    </article>
                  </div>

                  <div class="participant-stats-grid">
                    <article class="participant-stat-card participant-stat-card--blue">
                      <span class="participant-stat-label">Dataller</span>
                      <strong id="statDataller" class="participant-stat-value">Sin sesión</strong>
                      <span id="statDatallerMeta" class="participant-stat-meta">Activa tu participación</span>
                    </article>
                    <article class="participant-stat-card participant-stat-card--go">
                      <span class="participant-stat-label">Presentación</span>
                      <strong id="statSlides" class="participant-stat-value">0</strong>
                      <span id="statSlidesMeta" class="participant-stat-meta">Slides visibles</span>
                    </article>
                    <article class="participant-stat-card participant-stat-card--sky">
                      <span class="participant-stat-label">Comunidad</span>
                      <strong id="statMembers" class="participant-stat-value">0</strong>
                      <span id="statMembersMeta" class="participant-stat-meta">Personas en Dataller</span>
                    </article>
                    <article class="participant-stat-card participant-stat-card--warn">
                      <span class="participant-stat-label">Comentarios</span>
                      <strong id="statComments" class="participant-stat-value">0</strong>
                      <span id="statCommentsMeta" class="participant-stat-meta">Notas compartidas</span>
                    </article>
                  </div>
                </section>

                <section id="datallerSection" class="participant-admin-section">
                  <div class="participant-admin-section-head">
                    <p class="participant-admin-section-kicker">Dataller</p>
                    <h3 class="participant-admin-section-title">Presentación activa y comentarios</h3>
                  </div>

                  <div class="participant-workspace-grid">
                    <article class="participant-panel">
                      <p class="participant-panel-label">Acceso</p>
                      <h3 class="participant-panel-title">Activa tu participación</h3>
                      <p id="datallerSummary" class="participant-panel-copy" hidden></p>
                      <div class="participant-lockbox participant-lockbox--compact">
                        <span id="datallerState" class="participant-lock-state">Sin sesión</span>
                        <p id="datallerCopy" class="participant-panel-copy"></p>
                        <div class="participant-inline-actions">
                          <button id="datallerToggleBtn" class="button-secondary" type="button" disabled>Activar Dataller</button>
                        </div>
                      </div>
                      <div id="datallerStatus" class="registro-status" hidden></div>
                    </article>

                    <article class="participant-panel participant-panel--presentation">
                      <div class="participant-presentation-head">
                        <div>
                          <p class="participant-panel-label">Presentación</p>
                          <h3 id="presentationTitle" class="participant-panel-title">Activa Dataller para abrir la presentación</h3>
                        </div>
                        <span id="slideCounter" class="participant-doc-tag">0 / 0</span>
                      </div>
                      <p id="presentationDescription" class="participant-panel-copy" hidden></p>
                      <div id="presentationViewer" class="participant-slide-viewer participant-slide-viewer--locked">
                        <span id="slideTag" class="participant-doc-tag">Dataller</span>
                        <h4 id="slideTitle" class="participant-slide-title">Sin acceso todavía</h4>
                        <p id="slideSubtitle" class="participant-slide-subtitle">Activa Dataller para ver el contenido del taller.</p>
                        <div id="slideBody" class="participant-slide-body">Aquí aparecerá el contenido de la presentación activa.</div>
                        <div id="slideConcepts" class="participant-concept-list"></div>
                      </div>
                      <div class="participant-presentation-actions">
                        <button id="slidePrevBtn" class="button-secondary" type="button" disabled>Anterior</button>
                        <button id="slideNextBtn" class="button-secondary" type="button" disabled>Siguiente</button>
                      </div>
                    </article>
                  </div>

                  <article class="participant-panel participant-panel--wide participant-panel--comments">
                    <div class="participant-comments-head">
                      <div>
                        <p class="participant-panel-label">Comentarios</p>
                        <h3 class="participant-panel-title">Comparte observaciones sobre la presentación</h3>
                      </div>
                      <span id="commentsCountLabel" class="participant-doc-tag">0 comentarios</span>
                    </div>
                    <form id="commentForm" class="participant-comment-form">
                      <textarea id="commentBody" class="registro-input participant-textarea participant-textarea--comment" placeholder="Escribe un comentario útil para el resto del Dataller" maxlength="800" disabled></textarea>
                      <div class="participant-comment-actions">
                        <button id="commentSubmitBtn" class="button-secondary" type="submit" disabled>Publicar comentario</button>
                      </div>
                    </form>
                    <div id="commentStatus" class="registro-status" hidden></div>
                    <div id="commentList" class="participant-comment-list">
                      <div class="participant-comment-empty">Activa Dataller para ver y dejar comentarios.</div>
                    </div>
                  </article>
                </section>

                <section id="resourcesSection" class="participant-admin-section">
                  <div class="participant-admin-section-head">
                    <p class="participant-admin-section-kicker">Recursos</p>
                    <h3 class="participant-admin-section-title">Materiales del taller y biblioteca extendida</h3>
                  </div>

                  <div class="participant-resource-grid">
                    <article class="participant-panel">
                      <p class="participant-panel-label">Dataller</p>
                      <h3 class="participant-panel-title">Recursos del taller</h3>
                      <p id="datallerResourcesCopy" class="participant-panel-copy" hidden></p>
                      <div id="datallerResourceList" class="participant-link-list"></div>
                    </article>

                    <article class="participant-panel participant-panel--wide">
                      <p class="participant-panel-label">Biblioteca educativa</p>
                      <h3 class="participant-panel-title">Mapa curado desde el tema 2026</h3>
                      <div id="educationalResourceGroups" class="participant-resource-groups"></div>
                    </article>
                  </div>

                  <div class="participant-resource-grid participant-resource-grid--story">
                    <article class="participant-panel participant-panel--wide">
                      <p class="participant-panel-label">Panorama 2026</p>
                      <h3 class="participant-panel-title">Señales para entender el marco del evento</h3>
                      <div id="strategicSignalGrid" class="participant-signal-grid"></div>
                    </article>

                    <article class="participant-panel participant-panel--wide">
                      <p class="participant-panel-label">Ejes</p>
                      <h3 class="participant-panel-title">Temas que sostienen la conversación del Data Driven Day</h3>
                      <div id="themeAxisList" class="participant-axis-grid"></div>
                    </article>

                    <article class="participant-panel">
                      <p class="participant-panel-label">Arquitectura emergente</p>
                      <h3 class="participant-panel-title">Stack 2026 recomendado</h3>
                      <div id="currentStackList" class="participant-stack-list"></div>
                    </article>

                    <article class="participant-panel">
                      <p class="participant-panel-label">Riesgo técnico</p>
                      <h3 class="participant-panel-title">Patrones que ya vienen de salida</h3>
                      <div id="legacyStackList" class="participant-stack-list"></div>
                    </article>

                    <article class="participant-panel participant-panel--wide">
                      <p class="participant-panel-label">Benchmarks</p>
                      <h3 class="participant-panel-title">Proyectos y referencias para pensar casos reales</h3>
                      <div id="benchmarkProjectList" class="participant-benchmark-grid"></div>
                    </article>
                  </div>
                </section>

                <section id="communitySection" class="participant-admin-section">
                  <div class="participant-admin-section-head">
                    <p class="participant-admin-section-kicker">Comunidad</p>
                    <h3 class="participant-admin-section-title">Quiénes más están en el Dataller</h3>
                  </div>

                  <article class="participant-panel participant-panel--wide">
                    <div id="communityList" class="participant-member-grid">
                      <div class="participant-member-empty">Activa Dataller para ver la comunidad.</div>
                    </div>
                  </article>
                </section>

                <section id="profileSection" class="participant-admin-section">
                  <div class="participant-admin-section-head">
                    <p class="participant-admin-section-kicker">Perfil</p>
                    <h3 class="participant-admin-section-title">Actualiza tu perfil</h3>
                  </div>

                    <article class="participant-panel participant-panel--wide">
                      <form id="profileForm" class="participant-form-grid participant-form-grid--profile">
                        <label class="registro-field">
                          <span class="registro-field-label">Nombre en reconocimiento</span>
                          <input class="registro-input" type="text" name="fullName" placeholder="Tu nombre completo" maxlength="120" />
                        </label>
                        <label class="registro-field">
                          <span class="registro-field-label">Ocupación</span>
                          <input class="registro-input" type="text" name="occupation" placeholder="Desarrollador, Diseñador…" maxlength="120" />
                        </label>
                        <label class="registro-field">
                          <span class="registro-field-label">Escuela o trabajo</span>
                          <input class="registro-input" type="text" name="organization" placeholder="Nombre de empresa o institución" maxlength="120" />
                        </label>
                        <label class="registro-field">
                          <span class="registro-field-label">URL de proyecto</span>
                          <input class="registro-input" type="url" name="projectUrl" placeholder="https://" />
                        </label>
                        <label class="registro-field">
                          <span class="registro-field-label">URL de foto</span>
                          <input class="registro-input" type="url" name="avatarUrl" placeholder="https://" />
                        </label>
                        <label class="registro-field registro-field--wide">
                          <span class="registro-field-label">Bio corta</span>
                          <textarea class="registro-input participant-textarea participant-textarea--wide" name="bio" placeholder="Cuéntanos un poco sobre ti" maxlength="500"></textarea>
                        </label>
                        <button class="button-secondary" type="submit">Guardar perfil</button>
                      </form>
                      <div id="profileStatus" class="registro-status" role="status" aria-live="polite" hidden></div>
                    </article>

                    <article class="participant-panel participant-panel--wide" id="deleteAccountPanel">
                      <p class="participant-panel-label">Zona de peligro</p>
                      <h3 class="participant-panel-title">Eliminar cuenta</h3>
                      <p class="participant-panel-copy">Esta acción es permanente. Se borrarán tu perfil, comentarios y participación. No se puede deshacer.</p>
                      <details class="participant-danger-details">
                        <summary class="button-danger">Eliminar mi cuenta</summary>
                        <form id="deleteAccountForm" class="participant-form-grid participant-form-grid--delete">
                          <label class="registro-field registro-field--full">
                            <span class="registro-field-label">Confirma tu contraseña actual</span>
                            <input class="registro-input" type="password" name="password" placeholder="Tu contraseña" required autocomplete="current-password" />
                          </label>
                          <div id="deleteAccountStatus" class="registro-status" role="status" aria-live="polite" hidden></div>
                          <button class="button-danger" type="submit">Confirmar eliminación</button>
                        </form>
                      </details>
                    </article>
                </section>
              </main>
            </div>
            <div id="sidebarOverlay" class="participant-sidebar-overlay" aria-hidden="true"></div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <script id="participantStaticData" type="application/json" set:html={JSON.stringify(staticDashboardData)} />

  <script is:inline src="/scripts/recognition-pdf.js"></script>
  <script is:inline src="/scripts/participant-dashboard.js"></script>

</BaseLayout>

---
import AdminLayout from '../../../components/admin/AdminLayout.astro';

const cookie = Astro.request.headers.get('cookie') ?? '';
if (!/ddd_session=/.test(cookie)) return Astro.redirect('/admin/login');

const usuario = { username: '...', rol: 'editor', nombre: null };
---

<AdminLayout titulo="Presentaciones" seccion="presentaciones" usuario={usuario}>

  <div class="topbar-acciones" slot="acciones">
    <button class="admin-btn admin-btn--primary" id="btnNueva" type="button">+ Nueva</button>
  </div>

  <div class="pres-list" id="presList">
    <p class="stat-sub">Cargando...</p>
  </div>

  <script>
// @ts-nocheck
    async function load() {
      const res = await fetch('/api/admin/presentaciones');
      if (!res.ok) { if (res.status === 401) window.location.href = '/admin/login'; return; }
      const data = await res.json();
      const list = document.getElementById('presList');

      if (!data.presentations?.length) {
        list.innerHTML = '<p class="stat-sub">No hay presentaciones. Crea una nueva.</p>';
        return;
      }

      list.innerHTML = data.presentations.map(p => `
        <div class="pres-card">
          <div class="pres-card-info">
            <span class="pres-card-nombre">${p.nombre}</span>
            <span class="pres-card-meta">
              <span class="estado-badge estado-badge--${p.estado}">${p.estado}</span>
              <span>${p.slug}</span>
            </span>
          </div>
          <div class="pres-card-actions">
            <a href="/admin/presentaciones/${p.id}" class="table-action-btn">Editar</a>
            <button class="table-action-btn table-action-btn--danger" data-delete="${p.id}" type="button">Eliminar</button>
          </div>
        </div>
      `).join('');

      list.addEventListener('click', async (e) => {
        const btn = e.target.closest('[data-delete]');
        if (!btn) return;
        if (!confirm('Eliminar esta presentacion y todos sus slides?')) return;
        await fetch('/api/admin/presentaciones/' + btn.dataset.delete, { method: 'DELETE' });
        load();
      });
    }

    document.getElementById('btnNueva')?.addEventListener('click', async () => {
      const nombre = prompt('Nombre de la presentacion:');
      if (!nombre) return;
      const slug = nombre.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
      const token = crypto.randomUUID().slice(0, 8);
      const res = await fetch('/api/admin/presentaciones', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, slug, token }),
      });
      if (res.ok) {
        const data = await res.json();
        window.location.href = '/admin/presentaciones/' + data.id;
      }
    });

    load();
  </script>

</AdminLayout>

---
// Presenter mode — full-screen, keyboard-driven slide viewer
// Navegación: ← → (slides), N (notas), F (fullscreen), ESC (salir notas)
const cookie = Astro.request.headers.get('cookie') ?? '';
const isAdmin = /ddd_session=/.test(cookie);
---

<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Presenter · Data Driven Day</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d1117;
      --surface: #161b22;
      --border: rgba(255,255,255,0.08);
      --text: #e6edf3;
      --muted: #8b949e;
      --mono: 'DM Mono', 'Fira Code', monospace;
      --display: 'DM Sans', system-ui, sans-serif;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg); color: var(--text);
      font-family: var(--display);
    }

    /* ── TOPBAR ─────────────────────────────────────────── */
    .pres-topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      min-height: 40px;
      display: flex; align-items: center; justify-content: space-between;
      gap: 0.75rem;
      padding: 0 1.25rem;
      background: rgba(13,17,23,0.9);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      opacity: 1; transition: opacity 0.4s ease;
    }
    .pres-topbar.hidden { opacity: 0; pointer-events: none; }
    .topbar-brand {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.12em; color: var(--muted);
    }
    .topbar-center {
      font-family: var(--mono); font-size: 0.7rem;
      color: var(--muted); letter-spacing: 0.08em;
      flex: 1 1 auto;
      min-width: 0;
      text-align: center;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .topbar-actions {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      justify-content: flex-end;
      flex: 0 1 auto;
      min-width: 0;
      flex-wrap: wrap;
    }
    .topbar-actions > * {
      flex: 0 0 auto;
    }
    .topbar-btn {
      font-family: var(--mono); font-size: 0.65rem; font-weight: 600;
      padding: 0.2em 0.7em; border-radius: 3px; cursor: pointer;
      text-decoration: none; border: 1px solid var(--border);
      background: transparent; color: var(--muted);
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .topbar-btn:hover { background: var(--surface); color: var(--text); border-color: rgba(255,255,255,0.2); }
    .slide-counter {
      font-family: var(--mono); font-size: 0.7rem; color: var(--muted);
    }

    /* ── STAGE ──────────────────────────────────────────── */
    .pres-stage {
      position: fixed; inset: 0;
      display: flex; align-items: center; justify-content: center;
    }

    canvas {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
    }

    /* ── SLIDE HUD ──────────────────────────────────────── */
    .slide-hud {
      position: relative; z-index: 10;
      width: 100%; max-width: 1000px;
      padding: 0 4rem;
      pointer-events: none;
    }
    .slide-meta {
      display: flex; align-items: center; gap: 0.75rem;
      margin-bottom: 1.5rem;
    }
    .slide-num {
      font-family: var(--mono); font-size: 0.65rem; font-weight: 700;
      color: var(--accent, #34d399); letter-spacing: 0.1em;
    }
    .slide-divider { color: var(--muted); opacity: 0.4; }
    .slide-tag {
      font-family: var(--mono); font-size: 0.65rem; font-weight: 600;
      color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase;
    }
    .slide-titulo {
      font-family: var(--display);
      font-size: clamp(2.4rem, 5.5vw, 5rem);
      font-weight: 800; line-height: 1.0;
      color: var(--text);
      letter-spacing: -0.03em;
      margin-bottom: 1rem;
    }
    .slide-subtitulo {
      font-size: clamp(1rem, 2vw, 1.35rem);
      color: var(--muted);
      font-weight: 400; line-height: 1.5;
      margin-bottom: 1.5rem;
    }
    .slide-cuerpo {
      font-size: clamp(0.85rem, 1.4vw, 1.05rem);
      color: rgba(230,237,243,0.65);
      line-height: 1.7; max-width: 680px;
      margin-bottom: 1.5rem;
    }
    .slide-concepts {
      display: flex; flex-wrap: wrap; gap: 0.4rem;
    }
    .concept-pill {
      font-family: var(--mono); font-size: 0.62rem; font-weight: 600;
      padding: 0.25em 0.7em;
      border: 1px solid var(--accent, #34d399);
      color: var(--accent, #34d399); border-radius: 2px;
      text-transform: uppercase; letter-spacing: 0.08em;
    }

    .slide-imagen {
      max-width: 60%; max-height: 32vh;
      border-radius: 4px; margin-top: 1.2rem;
      object-fit: contain;
    }

    /* ── NAVIGATION ARROWS ──────────────────────────────── */
    .pres-nav {
      position: fixed; bottom: 2rem;
      left: 50%; transform: translateX(-50%);
      z-index: 100;
      display: flex; gap: 0.75rem; align-items: center;
      opacity: 1; transition: opacity 0.4s ease;
    }
    .pres-nav.hidden { opacity: 0; pointer-events: none; }
    .nav-btn {
      width: 40px; height: 40px;
      background: rgba(22,27,34,0.9);
      border: 1px solid var(--border);
      border-radius: 4px; cursor: pointer;
      color: var(--text); font-size: 1rem;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, border-color 0.15s;
    }
    .nav-btn:hover { background: var(--surface); border-color: rgba(255,255,255,0.2); }
    .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .nav-progress {
      font-family: var(--mono); font-size: 0.68rem; color: var(--muted);
      min-width: 4rem; text-align: center;
    }

    /* ── NOTES PANEL ────────────────────────────────────── */
    .notes-panel {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
      max-height: 35vh;
      background: rgba(13,17,23,0.97);
      border-top: 1px solid var(--border);
      backdrop-filter: blur(12px);
      transform: translateY(100%);
      transition: transform 0.3s ease;
      padding: 1.25rem 2rem;
      overflow-y: auto;
    }
    .notes-panel.open { transform: translateY(0); }
    .notes-label {
      font-family: var(--mono); font-size: 0.58rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--accent, #34d399);
      margin-bottom: 0.6rem;
    }
    .notes-text {
      font-size: 0.95rem; color: var(--text);
      line-height: 1.7; white-space: pre-wrap;
    }
    .notes-empty {
      font-size: 0.85rem; color: var(--muted); font-style: italic;
    }
    .notes-close {
      position: absolute; top: 0.75rem; right: 1.25rem;
      background: none; border: none; color: var(--muted);
      font-size: 1.1rem; cursor: pointer; padding: 0.25rem;
    }
    .notes-close:hover { color: var(--text); }

    /* ── TRANSITION ─────────────────────────────────────── */
    .slide-hud { transition: opacity 0.25s ease, transform 0.25s ease; }
    .slide-hud.exit-left  { opacity: 0; transform: translateX(-3%); }
    .slide-hud.exit-right { opacity: 0; transform: translateX(3%); }
    .slide-hud.enter      { opacity: 1; transform: translateX(0); }

    /* ── FULLSCREEN INDICATOR ───────────────────────────── */
    .hint-bar {
      position: fixed; top: 50px; left: 50%; transform: translateX(-50%);
      z-index: 50;
      font-family: var(--mono); font-size: 0.62rem; color: var(--muted);
      background: rgba(13,17,23,0.85);
      border: 1px solid var(--border); border-radius: 3px;
      padding: 0.3em 0.8em;
      opacity: 0; pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .hint-bar.show { opacity: 1; }

    /* ── LOADING ─────────────────────────────────────────── */
    .pres-loading {
      position: fixed; inset: 0; z-index: 300;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg);
      font-family: var(--mono); font-size: 0.75rem; color: var(--muted);
      letter-spacing: 0.1em; text-transform: uppercase;
    }

    /* ── TIMER ────────────────────────────────────────────── */
    .pres-timer {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      min-height: 28px;
      padding: 0.2rem 0.65rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(13,17,23,0.92);
      font-family: var(--mono); font-size: 0.65rem; font-weight: 600;
      color: var(--muted); letter-spacing: 0.06em;
      opacity: 1; transition: opacity 0.4s ease;
    }
    .pres-timer.hidden { opacity: 0; pointer-events: none; }
    .timer-slide { color: var(--accent, #34d399); }
    .timer-total { color: var(--muted); }
    .timer-over { color: #f87171; animation: timer-blink 1s ease-in-out infinite; }
    @keyframes timer-blink { 50% { opacity: 0.4; } }
    .timer-divider { opacity: 0.3; }

    @media (max-width: 980px) {
      .topbar-center {
        display: none;
      }
      .topbar-actions {
        gap: 0.35rem;
      }
      .topbar-btn {
        padding: 0.2em 0.55em;
      }
    }

    @media (max-width: 720px) {
      .pres-topbar {
        padding: 0.45rem 0.75rem;
        padding-right: 0.75rem;
        align-items: flex-start;
        flex-wrap: wrap;
      }
      .topbar-brand {
        width: 100%;
        font-size: 0.62rem;
      }
      .topbar-actions {
        width: 100%;
        justify-content: flex-start;
        gap: 0.3rem;
      }
      .slide-counter {
        order: 1;
      }
      .pres-timer {
        order: 2;
        margin-left: auto;
      }
      #btnVoice,
      #btnSubtitles,
      #btnGraph,
      #btnFullscreen,
      #btnNotes {
        order: 3;
      }
      .topbar-btn,
      .slide-counter {
        font-size: 0.58rem;
      }
      .pres-timer {
        min-height: 24px;
        padding: 0.15rem 0.5rem;
      }
      .graph-mode-banner,
      .voice-flash {
        max-width: calc(100vw - 1.5rem);
        white-space: normal;
        text-align: center;
      }
    }

    @media (max-width: 520px) {
      .topbar-actions {
        gap: 0.25rem;
      }
      .topbar-btn {
        padding: 0.18em 0.48em;
      }
      .slide-counter {
        display: none;
      }
      .pres-timer {
        margin-left: 0;
      }
      #btnVoice,
      #btnFullscreen,
      #btnNotes {
        letter-spacing: 0;
      }
    }

    /* ── NEXT SLIDE PREVIEW ──────────────────────────────── */
    .next-preview {
      position: fixed; bottom: 5.5rem; right: 1.5rem; z-index: 95;
      width: 220px;
      background: rgba(13,17,23,0.92);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.6rem 0.8rem;
      backdrop-filter: blur(8px);
      opacity: 0; transform: translateY(8px);
      transition: opacity 0.3s ease, transform 0.3s ease;
      pointer-events: none;
    }
    .next-preview.show { opacity: 1; transform: translateY(0); }
    .next-preview-label {
      font-family: var(--mono); font-size: 0.5rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--accent, #34d399);
      margin-bottom: 0.35rem;
    }
    .next-preview-title {
      font-size: 0.78rem; font-weight: 600; color: var(--text);
      line-height: 1.3;
      overflow: hidden; text-overflow: ellipsis;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    }
    .next-preview-tag {
      font-family: var(--mono); font-size: 0.5rem;
      color: var(--muted); margin-top: 0.25rem;
      text-transform: uppercase; letter-spacing: 0.08em;
    }

    /* ── SUMMARY OVERLAY ─────────────────────────────────── */
    .summary-overlay {
      position: fixed; inset: 0; z-index: 9998;
      display: none; align-items: center; justify-content: center;
      background: rgba(13,17,23,0.96);
      backdrop-filter: blur(12px);
    }
    .summary-overlay.active { display: flex; }
    .summary-box {
      max-width: 700px; width: 90%;
      max-height: 80vh; overflow-y: auto;
      padding: 2.5rem;
    }
    .summary-label {
      font-family: var(--mono); font-size: 0.6rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--accent, #34d399);
      margin-bottom: 1rem;
    }
    .summary-text {
      font-size: 1.05rem; color: var(--text);
      line-height: 1.8; white-space: pre-wrap;
    }
    .summary-text.loading {
      color: var(--muted); font-style: italic;
    }
    .summary-close {
      position: absolute; top: 1.5rem; right: 1.5rem;
      background: none; border: none; color: var(--muted);
      font-size: 1.4rem; cursor: pointer;
    }
    .summary-close:hover { color: var(--text); }

    /* ── CONCEPT GRAPH ────────────────────────────────────── */
    .graph-overlay {
      position: fixed; inset: 0; z-index: 15;
      pointer-events: none;
      opacity: 0; transition: opacity 0.5s ease;
    }
    .graph-overlay::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 45%, rgba(52,211,153,0.12), transparent 28%),
        radial-gradient(circle at 20% 20%, rgba(255,255,255,0.05), transparent 22%),
        linear-gradient(180deg, rgba(13,17,23,0.94), rgba(8,12,18,0.98));
      opacity: 0;
      transition: opacity 0.35s ease;
    }
    .graph-overlay.active { opacity: 1; }
    body.graph-focus .graph-overlay { opacity: 1; }
    body.graph-focus .graph-overlay::before { opacity: 1; }
    body.graph-focus canvas {
      opacity: 0.06;
      filter: blur(4px);
      transition: opacity 0.25s ease, filter 0.25s ease;
    }
    body.graph-focus .pres-topbar,
    body.graph-focus .slide-hud,
    body.graph-focus .pres-nav,
    body.graph-focus .next-preview,
    body.graph-focus .notes-panel,
    body.graph-focus .pres-timer,
    body.graph-focus .subtitle-bar {
      opacity: 0;
      pointer-events: none;
    }
    body.graph-focus .pres-topbar {
      transform: translateY(-100%);
    }
    .graph-svg {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
    }
    .graph-svg line {
      stroke: var(--accent, #34d399);
      stroke-width: 1.8;
      stroke-opacity: 0.42;
      stroke-dasharray: 200;
      stroke-dashoffset: 200;
      filter: drop-shadow(0 0 8px rgba(52,211,153,0.2));
      animation: edge-draw 0.8s ease-out forwards;
      transition: stroke-opacity 0.25s ease, stroke-width 0.25s ease;
    }
    .graph-svg line.active {
      stroke-opacity: 0.9;
      stroke-width: 2.6;
    }
    @keyframes edge-draw {
      to { stroke-dashoffset: 0; }
    }
    .graph-nodes {
      position: absolute; inset: 0;
    }
    .graph-node {
      position: absolute;
      font-family: var(--mono); font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--accent, #34d399);
      border: 1px solid var(--accent, #34d399);
      background: rgba(13,17,23,0.82);
      backdrop-filter: blur(4px);
      border-radius: 4px;
      padding: 0.3em 0.7em;
      white-space: nowrap;
      transform: translate(-50%, -50%) scale(0);
      box-shadow: 0 10px 28px rgba(0,0,0,0.28);
      animation: node-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards, node-float 7s ease-in-out infinite;
      transition: left 0.6s ease, top 0.6s ease;
    }
    .graph-node.root {
      font-size: 1.15rem;
      padding: 0.55em 1.1em;
      border-width: 2px;
      background: rgba(13,17,23,0.98);
      box-shadow: 0 0 0 1px rgba(52, 211, 153, 0.12), 0 0 28px rgba(52,211,153,0.16), 0 18px 44px rgba(0,0,0,0.38);
      z-index: 2;
      animation: node-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards, node-root-pulse 2.8s ease-in-out infinite;
    }
    .graph-node.seed {
      border-style: dashed;
      opacity: 0.55;
      transform: translate(-50%, -50%) scale(1);
      animation: node-float 8s ease-in-out infinite;
    }
    .graph-node.seed.mentioned {
      opacity: 1;
      border-style: solid;
      animation: node-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards, node-float 6.5s ease-in-out infinite;
    }
    .graph-node.incoming {
      animation: node-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards, node-flash 1.2s ease-out, node-float 6.8s ease-in-out infinite;
    }
    .graph-node.active {
      opacity: 1;
      box-shadow: 0 0 0 1px rgba(52, 211, 153, 0.2), 0 0 22px rgba(52,211,153,0.28), 0 14px 34px rgba(0,0,0,0.36);
    }
    @keyframes node-pop {
      0%   { transform: translate(-50%, -50%) scale(0); opacity: 0; }
      100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    }
    @keyframes node-flash {
      0% { filter: brightness(1.8); }
      100% { filter: brightness(1); }
    }
    @keyframes node-float {
      0%, 100% { transform: translate(-50%, -50%) translateY(0); }
      50% { transform: translate(-50%, -50%) translateY(-6px); }
    }
    @keyframes node-root-pulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); }
      50% { transform: translate(-50%, -50%) scale(1.03); }
    }
    .graph-mode-banner {
      position: fixed;
      top: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 120;
      padding: 0.55rem 1rem;
      border: 1px solid rgba(52, 211, 153, 0.35);
      border-radius: 999px;
      background: rgba(13,17,23,0.84);
      color: var(--accent, #34d399);
      font-family: var(--mono);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }
    body.graph-focus .graph-mode-banner {
      opacity: 1;
    }

    /* ── SUBTITLES ────────────────────────────────────────── */
    .subtitle-bar {
      position: fixed; bottom: 5rem; left: 50%; transform: translateX(-50%);
      z-index: 90;
      max-width: 80vw; min-width: 280px;
      padding: 0.6em 1.4em;
      font-family: var(--display); font-size: clamp(1rem, 2.2vw, 1.45rem);
      font-weight: 500; line-height: 1.5;
      color: #fff;
      background: rgba(0,0,0,0.72);
      backdrop-filter: blur(6px);
      border-radius: 6px;
      text-align: center;
      pointer-events: none;
      opacity: 1; transition: opacity 0.35s ease;
    }
    .subtitle-bar:empty, .subtitle-bar[hidden] { opacity: 0; }
    .subtitle-bar .interim { color: rgba(255,255,255,0.55); }

    /* ── VOICE ───────────────────────────────────────────── */
    .voice-dot {
      display: inline-block; width: 6px; height: 6px;
      border-radius: 50%; background: var(--muted);
      margin-right: 0.35em; vertical-align: middle;
      transition: background 0.2s;
    }
    .topbar-btn.voice-active { border-color: #34d399; color: #34d399; }
    .topbar-btn.voice-active .voice-dot {
      background: #34d399;
      animation: pulse-dot 1s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.4; transform: scale(1.5); }
    }
    .voice-flash {
      position: fixed; top: 52px; left: 50%; transform: translateX(-50%);
      z-index: 500;
      font-family: var(--mono); font-size: 0.68rem; font-weight: 700;
      color: #34d399; letter-spacing: 0.08em; text-transform: uppercase;
      background: rgba(13,17,23,0.96); border: 1px solid #34d399;
      border-radius: 3px; padding: 0.35em 1em;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s ease;
      white-space: nowrap;
    }
    .voice-flash.show { opacity: 1; }

    .debug-panel {
      position: fixed;
      top: 54px;
      right: 1rem;
      z-index: 160;
      width: min(360px, calc(100vw - 2rem));
      padding: 0.8rem 0.9rem;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      background: rgba(13,17,23,0.92);
      backdrop-filter: blur(12px);
      box-shadow: 0 14px 40px rgba(0,0,0,0.35);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-6px);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .debug-panel.visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }
    .debug-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
    }
    .debug-title {
      font-family: var(--mono);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent, #34d399);
    }
    .debug-pill {
      padding: 0.2rem 0.5rem;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 999px;
      font-family: var(--mono);
      font-size: 0.55rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .debug-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem 0.6rem;
      margin-bottom: 0.7rem;
    }
    .debug-item {
      min-width: 0;
    }
    .debug-label {
      display: block;
      margin-bottom: 0.2rem;
      font-family: var(--mono);
      font-size: 0.52rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .debug-value {
      display: block;
      min-height: 1.3em;
      font-family: var(--mono);
      font-size: 0.66rem;
      line-height: 1.4;
      color: var(--text);
      word-break: break-word;
    }
    .debug-value.is-error {
      color: #f87171;
    }
    .debug-value.is-good {
      color: #34d399;
    }
    .debug-transcript {
      padding-top: 0.65rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .debug-transcript-text {
      margin-top: 0.3rem;
      font-size: 0.72rem;
      line-height: 1.5;
      color: rgba(230,237,243,0.88);
      white-space: pre-wrap;
    }

    @media (max-width: 720px) {
      .debug-panel {
        top: auto;
        right: 0.75rem;
        bottom: 5.25rem;
        width: calc(100vw - 1.5rem);
      }
      .debug-grid {
        grid-template-columns: 1fr;
      }
    }

    .atencion-overlay {
      position: fixed; inset: 0; z-index: 9999;
      display: flex; align-items: center; justify-content: center;
      background: #fbbf24;
      visibility: hidden;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease;
    }
    .atencion-overlay.active {
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
      animation: atencion-in 0.25s ease-out;
    }
    .atencion-overlay.active .atencion-text {
      animation: atencion-pulse 0.8s ease-in-out infinite alternate;
    }
    .atencion-text {
      font-family: var(--mono); font-size: clamp(4rem, 12vw, 10rem);
      font-weight: 900; color: #000; letter-spacing: 0.06em;
      text-align: center;
    }
    @keyframes atencion-in {
      from { opacity: 0; transform: scale(1.15); }
      to   { opacity: 1; transform: scale(1); }
    }
    @keyframes atencion-pulse {
      from { transform: scale(1); }
      to   { transform: scale(1.04); }
    }
  </style>
</head>
<body>


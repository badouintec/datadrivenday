  <script>
// @ts-nocheck
const PARTICLE_COUNT = 400;
const ACCENT_COLORS = [
  { id: 'primary', hex: '#34d399' },
  { id: 'alert',   hex: '#f87171' },
  { id: 'sage',    hex: '#8EA676' },
  { id: 'light',   hex: '#EAEBE6' },
  { id: 'amber',   hex: '#fbbf24' },
];

const STATE = {
  slides: [],
  idx: 0,
  particles: [],
  animTime: 0,
  animFrame: null,
  lastFrameTime: 0,
  canvas: null,
  ctx: null,
  notesOpen: false,
  uiHideTimer: null,
  audioCtx: null,
  recognition: null,
  voiceActive: false,
  voiceFlashTimer: null,
  voiceRestartAttempts: 0,
  micStream: null,
  micSource: null,
  analyser: null,
  analyserData: null,
  voiceLevel: 0,
  voicePitch: 0,
  reactiveAccent: null,
  reactiveAccentUntil: 0,
  atencionTimer: null,
  subtitlesOn: false,
  subtitleTimer: null,
  schemaActive: false,
  schemaWords: new Map(),   // id → { label, x, y, el, tier, parentId }
  schemaLines: [],          // { fromId, toId, el }
  debugVisible: false,
  debugSpeechAvailable: false,
  debugVoiceStatus: 'inactiva',
  debugMicStatus: 'pendiente',
  debugRecognitionStatus: 'sin inicializar',
  debugLastCommand: 'ninguno',
  debugTranscript: 'sin texto',
  debugLastError: 'sin errores',
  // Timer
  presStartTime: 0,
  slideStartTime: 0,
  // Next preview
  nextPreviewVisible: false,
  // Summary
  allTranscripts: '',
  presentation: null,
  // AI Chat
  chatOpen: false,
  chatHistory: [],
  chatVoiceCapture: false,
  chatVoiceBuffer: '',
  chatVoiceSilenceTimer: null,
  // DOM cache (populated in init)
  dom: {},
};

const VOICE_COLOR_RULES = [
  { accent: 'alert', words: ['alerta', 'urgente', 'riesgo', 'crisis', 'rojo', 'peligro'] },
  { accent: 'amber', words: ['dato', 'datos', 'valor', 'señal', 'senal', 'oportunidad'] },
  { accent: 'sage', words: ['salud', 'verde', 'territorio', 'sistema', 'equilibrio'] },
  { accent: 'light', words: ['luz', 'claro', 'claridad', 'blanco', 'transparencia'] },
  { accent: 'primary', words: ['ia', 'inteligencia', 'modelo', 'agente', 'copilot', 'automatizacion', 'automatización'] },
];

function normalizeSpeechText(value) {
  return String(value ?? '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9\s]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

// ── SCHEMA / WORD MAP SYSTEM ──────────────────────────────────
const SCHEMA_STOPWORDS = new Set([
  'para', 'como', 'esta', 'este', 'estos', 'estas', 'vamos', 'puede', 'pueden', 'hacer', 'desde', 'hasta',
  'porque', 'tambien', 'entre', 'cada', 'todos', 'todas', 'solo', 'algo', 'nada', 'digamos', 'bueno',
  'pues', 'entonces', 'tener', 'tiene', 'modo', 'grafo', 'decir', 'hablar', 'habla', 'ahora', 'aqui',
  'sudo', 'suma', 'esto', 'esos', 'esas', 'otro', 'otra', 'pero', 'cuando', 'donde', 'quien',
  'sobre', 'bajo', 'tras', 'ante', 'contra', 'durante', 'mediante', 'segun', 'hacia',
  'sido', 'sera', 'sido', 'siendo', 'estan', 'estar', 'estamos', 'seria', 'fueron',
]);

const SCHEMA_TIERS = ['root', 'branch', 'leaf', 'whisper'];
const SCHEMA_COLORS = {
  root:    '#e6edf3',
  branch:  '#60a5fa',
  leaf:    '#34d399',
  whisper: '#7d8590',
};

function schemaUniqueTerms(values, limit = 8) {
  const unique = [];
  const seen = new Set();
  for (const raw of values) {
    const cleaned = String(raw ?? '').trim();
    const normalized = normalizeSpeechText(cleaned);
    if (!cleaned || !normalized || normalized.length < 3 || seen.has(normalized)) continue;
    seen.add(normalized);
    unique.push(cleaned);
    if (unique.length >= limit) break;
  }
  return unique;
}

function schemaDisplayLabel(value) {
  return String(value ?? '').trim()
    .split(/\s+/).slice(0, 4)
    .map(p => p.charAt(0).toUpperCase() + p.slice(1).toLowerCase())
    .join(' ');
}

function toggleSchema() {
  STATE.schemaActive = !STATE.schemaActive;
  const overlay = STATE.dom.schemaOverlay;
  if (!overlay) return;

  if (STATE.schemaActive) {
    overlay.classList.add('active');
    document.body.classList.add('schema-active');
    schemaSeedFromSlide(); // always re-seed for current slide
    if (!STATE.voiceActive) toggleVoice();
    showVoiceFlash('Esquema ON');
  } else {
    overlay.classList.remove('active');
    document.body.classList.remove('schema-active');
    showVoiceFlash('Esquema OFF');
    showUI(); // restore topbar/nav that may have been hidden while schema was active
  }
  STATE.dom.btnGraph?.classList.toggle('voice-active', STATE.schemaActive);
  updateDebugHud();
}

function clearSchema() {
  STATE.schemaWords.clear();
  STATE.schemaLines.forEach(l => l.el?.remove());
  STATE.schemaLines = [];
  if (STATE.dom.schemaCanvas) STATE.dom.schemaCanvas.innerHTML = '';
}

function schemaSeedFromSlide() {
  clearSchema();
  const slide = STATE.slides[STATE.idx];
  const w = window.innerWidth, h = window.innerHeight;

  // Root = slide title
  const rootLabel = slide?.titulo?.trim() || slide?.tag?.trim() || 'Tema';
  const rootId = normalizeSpeechText(rootLabel).replace(/\s+/g, '_') || 'tema';
  schemaAddWord(rootId, rootLabel, w * 0.5, h * 0.38, 'root', null);

  // Branches from slide data
  const branches = [];
  if (slide?.tag) branches.push(slide.tag);
  if (slide?.conceptosClave?.length) branches.push(...slide.conceptosClave);
  if (slide?.subtitulo) branches.push(...String(slide.subtitulo).split(/[,:;|]/));

  const uniqueBranches = schemaUniqueTerms(branches, 6)
    .filter(b => normalizeSpeechText(b) !== normalizeSpeechText(rootLabel));

  // Place branches in a creative arc around root
  const arcStart = -Math.PI * 0.7;
  const arcEnd = Math.PI * 0.5;
  uniqueBranches.forEach((label, i, arr) => {
    const id = normalizeSpeechText(label).replace(/\s+/g, '_');
    const t = arr.length === 1 ? 0.5 : i / (arr.length - 1);
    const angle = arcStart + t * (arcEnd - arcStart);
    const rx = Math.min(w * 0.28, 350) + (i % 2) * 40;
    const ry = Math.min(h * 0.25, 220) + (i % 2) * 30;
    const x = w * 0.5 + Math.cos(angle) * rx;
    const y = h * 0.38 + Math.sin(angle) * ry;
    schemaAddWord(id, schemaDisplayLabel(label), x, y, 'branch', rootId);
    schemaAddLine(rootId, id);
  });
}

function schemaAddWord(id, label, x, y, tier, parentId) {
  if (STATE.schemaWords.has(id)) {
    // Flash existing word
    const existing = STATE.schemaWords.get(id);
    existing.el.classList.add('flash');
    setTimeout(() => existing.el.classList.remove('flash'), 1000);
    return;
  }

  const container = STATE.dom.schemaCanvas;
  if (!container) return;

  const el = document.createElement('div');
  el.className = 'schema-word ' + tier;
  el.textContent = label;
  el.style.left = x + 'px';
  el.style.top = y + 'px';
  container.appendChild(el);

  // Trigger animation after paint
  requestAnimationFrame(() => {
    requestAnimationFrame(() => el.classList.add('visible'));
  });

  STATE.schemaWords.set(id, { label, x, y, el, tier, parentId });

  // Cap at 50 words — remove oldest whispers
  if (STATE.schemaWords.size > 50) {
    for (const [oldId, oldWord] of STATE.schemaWords) {
      if (oldWord.tier === 'whisper') {
        oldWord.el.remove();
        STATE.schemaWords.delete(oldId);
        // Remove associated lines
        STATE.schemaLines = STATE.schemaLines.filter(l => {
          if (l.fromId === oldId || l.toId === oldId) { l.el?.remove(); return false; }
          return true;
        });
        break;
      }
    }
  }
}

function schemaAddLine(fromId, toId) {
  const from = STATE.schemaWords.get(fromId);
  const to = STATE.schemaWords.get(toId);
  if (!from || !to) return;
  // No duplicate lines
  if (STATE.schemaLines.some(l => (l.fromId === fromId && l.toId === toId) || (l.fromId === toId && l.toId === fromId))) return;

  const container = STATE.dom.schemaCanvas;
  if (!container) return;

  const el = document.createElement('div');
  el.className = 'schema-line';
  container.appendChild(el);
  positionLine(el, from.x, from.y, to.x, to.y);
  requestAnimationFrame(() => el.classList.add('visible'));

  STATE.schemaLines.push({ fromId, toId, el });
}

function positionLine(el, x1, y1, x2, y2) {
  const dx = x2 - x1, dy = y2 - y1;
  const len = Math.sqrt(dx * dx + dy * dy);
  const angle = Math.atan2(dy, dx);
  el.style.left = x1 + 'px';
  el.style.top = y1 + 'px';
  el.style.width = len + 'px';
  el.style.transform = 'rotate(' + angle + 'rad)';
}

function schemaUpdateLinePositions() {
  STATE.schemaLines.forEach(l => {
    const from = STATE.schemaWords.get(l.fromId);
    const to = STATE.schemaWords.get(l.toId);
    if (from && to && l.el) positionLine(l.el, from.x, from.y, to.x, to.y);
  });
}

// Soft repulsion so words don't overlap
function schemaNudge() {
  const words = [...STATE.schemaWords.values()];
  const w = window.innerWidth, h = window.innerHeight;
  const MIN_DIST = 80;

  for (let i = 0; i < words.length; i++) {
    for (let j = i + 1; j < words.length; j++) {
      const dx = words[j].x - words[i].x;
      const dy = words[j].y - words[i].y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      if (dist < MIN_DIST) {
        const push = (MIN_DIST - dist) * 0.025;
        const nx = (dx / dist) * push;
        const ny = (dy / dist) * push;
        // Don't push root
        if (words[i].tier !== 'root') { words[i].x -= nx; words[i].y -= ny; }
        if (words[j].tier !== 'root') { words[j].x += nx; words[j].y += ny; }
      }
    }
    // Keep within viewport with padding
    words[i].x = Math.max(80, Math.min(w - 80, words[i].x));
    words[i].y = Math.max(60, Math.min(h - 60, words[i].y));
    words[i].el.style.left = words[i].x + 'px';
    words[i].el.style.top = words[i].y + 'px';
  }
  schemaUpdateLinePositions();
}

// Expand schema from speech — add new concepts as they're spoken
function schemaExpandFromSpeech(text) {
  if (!STATE.schemaActive) return;
  const normalized = normalizeSpeechText(text);
  if (!normalized) return;

  // Find root
  const rootEntry = [...STATE.schemaWords.entries()].find(([, w]) => w.tier === 'root');
  if (!rootEntry) return;
  const rootId = rootEntry[0];

  const terms = normalized.split(' ')
    .filter(word => word.length >= 4 && !SCHEMA_STOPWORDS.has(word));

  const unique = schemaUniqueTerms(terms, 3);
  unique.forEach((term) => {
    const id = normalizeSpeechText(term).replace(/\s+/g, '_');
    if (!id || STATE.schemaWords.has(id)) {
      // Flash if exists
      if (STATE.schemaWords.has(id)) {
        const w = STATE.schemaWords.get(id);
        w.el.classList.add('flash');
        setTimeout(() => w.el.classList.remove('flash'), 1000);
      }
      return;
    }

    // Decide tier: if related to a branch, become leaf. Otherwise whisper.
    let parentId = rootId;
    let tier = 'whisper';
    const termWords = normalizeSpeechText(term).split(' ');

    for (const [wId, w] of STATE.schemaWords) {
      if (w.tier === 'root') continue;
      const labelWords = normalizeSpeechText(w.label).split(' ');
      if (termWords.some(tw => labelWords.includes(tw))) {
        parentId = wId;
        tier = w.tier === 'branch' ? 'leaf' : 'whisper';
        break;
      }
    }

    const parent = STATE.schemaWords.get(parentId);
    if (!parent) return;

    // Position near parent with some randomness
    const angle = -Math.PI + Math.random() * Math.PI * 2;
    const dist = tier === 'leaf' ? (100 + Math.random() * 80) : (60 + Math.random() * 100);
    const x = parent.x + Math.cos(angle) * dist;
    const y = parent.y + Math.sin(angle) * dist;

    schemaAddWord(id, schemaDisplayLabel(term), x, y, tier, parentId);
    schemaAddLine(parentId, id);
  });

  updateDebugHud();
}

// ── INIT ─────────────────────────────────────────────────
async function init() {
  // Cache DOM refs used in hot paths
  const $ = (id) => document.getElementById(id);
  STATE.dom = {
    topbar: $('topbar'), presNav: $('presNav'), presTimer: $('presTimer'),
    slideHud: $('slideHud'), slideNum: $('slideNum'), slideTag: $('slideTag'),
    slideTitulo: $('slideTitulo'), slideSubtitulo: $('slideSubtitulo'),
    slideCuerpo: $('slideCuerpo'), slideConcepts: $('slideConcepts'),
    slideImagen: $('slideImagen'), notesContent: $('notesContent'),
    timerSlide: $('timerSlide'), timerTotal: $('timerTotal'),
    navProgress: $('navProgress'), slideCounter: $('slideCounter'),
    btnPrev: $('btnPrev'), btnNext: $('btnNext'),
    voiceFlash: $('voiceFlash'), subtitleBar: $('subtitleBar'),
    nextPreview: $('nextPreview'), nextPreviewTitle: $('nextPreviewTitle'),
    nextPreviewTag: $('nextPreviewTag'), presTitle: $('presTitle'),
    btnVoice: $('btnVoice'), btnSubtitles: $('btnSubtitles'), btnGraph: $('btnGraph'),
    btnDebugHud: $('btnDebugHud'), debugPanel: $('debugPanel'), debugMode: $('debugMode'),
    debugVoiceStatus: $('debugVoiceStatus'), debugMicStatus: $('debugMicStatus'),
    debugRecognitionStatus: $('debugRecognitionStatus'), debugRestartAttempts: $('debugRestartAttempts'),
    debugLastCommand: $('debugLastCommand'), debugGraphStatus: $('debugGraphStatus'),
    debugGraphSource: $('debugGraphSource'), debugGraphNodes: $('debugGraphNodes'),
    debugTranscript: $('debugTranscript'), debugLastError: $('debugLastError'),
    atencionOverlay: $('atencionOverlay'),
    schemaOverlay: $('schemaOverlay'), schemaCanvas: $('schemaCanvas'), schemaLabel: $('schemaLabel'),
    chatPanel: $('chatPanel'), chatMessages: $('chatMessages'),
    chatInput: $('chatInput'), chatSendBtn: $('chatSendBtn'), btnChat: $('btnChat'),
  };

  STATE.canvas = $('presCanvas');
  STATE.ctx = STATE.canvas.getContext('2d');
  resizeCanvas();
  window.addEventListener('resize', () => {
    resizeCanvas();
    if (STATE.schemaActive) schemaSeedFromSlide();
  });
  initParticles();

  const params = new URLSearchParams(location.search);
  const presId = params.get('pres') ?? 'pres-dataller-2026';

  try {
    const res = await fetch(`/api/slides?presentacion=${presId}`);
    const data = await res.json();
    STATE.slides = (data.slides ?? []).filter(s => s.isActive !== false);
    STATE.presentation = data.presentation ?? null;
  } catch(e) {
    STATE.slides = [];
    STATE.presentation = null;
  }

  $('loading').style.display = 'none';

  // Ensure overlays are dismissed on load
  STATE.dom.atencionOverlay?.classList.remove('active');
  $('summaryOverlay')?.classList.remove('active');

  if (!STATE.slides.length) {
    STATE.dom.slideTitulo.textContent = 'Sin slides activos';
    STATE.dom.slideSubtitulo.textContent = 'Crea slides en el panel de admin';
    startLoop();
    return;
  }

  const now = performance.now();
  STATE.presStartTime = now;
  STATE.slideStartTime = now;

  renderSlide(0);
  bindEvents();
  updateDebugHud();
  startLoop();
  scheduleHideUI();
  initVoice();
}

function updateDebugHud() {
  const d = STATE.dom;
  if (!d.debugPanel) return;

  d.debugPanel.classList.toggle('visible', STATE.debugVisible);
  d.debugMode.textContent = STATE.debugVisible ? 'visible' : 'oculto';
  d.debugVoiceStatus.textContent = STATE.debugVoiceStatus;
  d.debugMicStatus.textContent = STATE.debugMicStatus;
  d.debugRecognitionStatus.textContent = STATE.debugRecognitionStatus;
  d.debugRestartAttempts.textContent = String(STATE.voiceRestartAttempts);
  d.debugLastCommand.textContent = STATE.debugLastCommand;
  d.debugGraphStatus.textContent = STATE.schemaActive ? 'activo' : 'inactivo';
  d.debugGraphSource.textContent = STATE.schemaWords.size ? 'con datos' : 'sin datos';
  d.debugGraphNodes.textContent = String(STATE.schemaWords.size);
  d.debugTranscript.textContent = STATE.debugTranscript;
  d.debugLastError.textContent = STATE.debugLastError;

  d.debugVoiceStatus.className = 'debug-value' + (STATE.voiceActive ? ' is-good' : '');
  d.debugMicStatus.className = 'debug-value' + (STATE.debugMicStatus === 'listo' ? ' is-good' : STATE.debugMicStatus.includes('bloqueado') || STATE.debugMicStatus.includes('no disponible') ? ' is-error' : '');
  d.debugRecognitionStatus.className = 'debug-value' + (STATE.debugRecognitionStatus.includes('escuchando') ? ' is-good' : STATE.debugRecognitionStatus.includes('error') ? ' is-error' : '');
  d.debugGraphStatus.className = 'debug-value' + (STATE.schemaActive ? ' is-good' : '');
  d.debugLastError.className = 'debug-transcript-text' + (STATE.debugLastError !== 'sin errores' ? ' is-error' : '');
}

function setDebugCommand(value) {
  STATE.debugLastCommand = value;
  updateDebugHud();
}

function setDebugError(value) {
  STATE.debugLastError = value;
  updateDebugHud();
}

function toggleDebugHud() {
  if (!STATE.dom.debugPanel) return;
  STATE.debugVisible = !STATE.debugVisible;
  updateDebugHud();
}

// ── SLIDE RENDERING ──────────────────────────────────────
function renderSlide(idx, direction) {
  const slides = STATE.slides;
  if (!slides.length) return;
  STATE.idx = idx;

  const slide = slides[idx];
  const hud = document.getElementById('slideHud');

  // Transition out
  if (direction) {
    hud.classList.remove('enter');
    hud.classList.add(direction === 'next' ? 'exit-left' : 'exit-right');
    setTimeout(() => {
      applySlide(slide);
      hud.classList.remove('exit-left', 'exit-right');
      hud.classList.add('enter');
      // Seed schema after slide HUD has finished transitioning to the new content
      if (STATE.schemaActive) schemaSeedFromSlide();
    }, 220);
  } else {
    applySlide(slide);
    if (STATE.schemaActive) schemaSeedFromSlide();
  }

  // Reset slide timer
  STATE.slideStartTime = performance.now();

  // Update nav (use cached DOM)
  const d = STATE.dom;
  d.btnPrev.disabled = idx === 0;
  d.btnNext.disabled = idx === slides.length - 1;
  d.navProgress.textContent = `${idx + 1} / ${slides.length}`;
  d.slideCounter.textContent = `${idx + 1} / ${slides.length}`;

  // Accent color on body
  const accentHex = ACCENT_COLORS.find(c => c.id === getActiveAccent(slide))?.hex ?? '#34d399';
  document.documentElement.style.setProperty('--accent', accentHex);

  // Next slide preview
  updateNextPreview(idx);

  // AI summary when reaching last slide
  if (idx === slides.length - 1 && STATE.allTranscripts.length > 100) {
    generateSummary();
  }
}

function applySlide(slide) {
  const d = STATE.dom;
  d.slideNum.textContent = String(slide.numero ?? 1).padStart(2, '0');
  d.slideTag.textContent = slide.tag ?? '';
  d.slideTitulo.textContent = slide.titulo ?? '';
  d.slideSubtitulo.textContent = slide.subtitulo ?? '';
  d.slideCuerpo.textContent = slide.cuerpo ?? '';

  const concepts = slide.conceptosClave ?? [];
  d.slideConcepts.innerHTML = concepts.map(c => {
    const safe = String(c).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return `<span class="concept-pill">${safe}</span>`;
  }).join('');

  // Slide image
  const imgUrl = slide.imagenUrl ?? slide.imagen_url ?? null;
  if (imgUrl) { d.slideImagen.src = imgUrl; d.slideImagen.hidden = false; }
  else { d.slideImagen.hidden = true; d.slideImagen.src = ''; }

  // Notes
  const notes = slide.notas ?? '';
  if (notes.trim()) {
    d.notesContent.innerHTML = `<p class="notes-text">${notes.replace(/</g,'&lt;')}</p>`;
  } else {
    d.notesContent.innerHTML = `<p class="notes-empty">Este slide no tiene notas.</p>`;
  }

  const chord = slide.chord ?? [];
  if (chord.length) playChord(chord);

  // Pres title
  d.presTitle.textContent = STATE.presentation?.nombre ?? 'Presentacion';
}

// ── EVENTS ───────────────────────────────────────────────
function bindEvents() {
  STATE.dom.btnPrev.addEventListener('click', () => go(-1));
  STATE.dom.btnNext.addEventListener('click', () => go(1));
  STATE.dom.btnDebugHud?.addEventListener('click', toggleDebugHud);
  document.getElementById('btnNotes').addEventListener('click', toggleNotes);
  document.getElementById('notesClose').addEventListener('click', closeNotes);
  document.getElementById('btnFullscreen').addEventListener('click', toggleFullscreen);
  document.getElementById('btnVoice').addEventListener('click', toggleVoice);
  document.getElementById('btnSubtitles').addEventListener('click', toggleSubtitles);
  document.getElementById('btnGraph').addEventListener('click', toggleSchema);
  document.getElementById('chatClose')?.addEventListener('click', closeChat);
  STATE.dom.btnChat?.addEventListener('click', toggleChat);
  STATE.dom.chatSendBtn?.addEventListener('click', sendChatMessage);
  STATE.dom.chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChatMessage(); }
  });
  document.getElementById('atencionOverlay').addEventListener('click', dismissAtencion);
  document.getElementById('summaryClose').addEventListener('click', closeSummary);

  document.addEventListener('keydown', (e) => {
    ensureAudioContext();
    if (e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') { e.preventDefault(); go(1); }
    if (e.key === 'ArrowLeft'  || e.key === 'PageUp')   { e.preventDefault(); go(-1); }
    if (e.key === 'n' || e.key === 'N') toggleNotes();
    if (e.key === 'f' || e.key === 'F') toggleFullscreen();
    if (e.key === 'v' || e.key === 'V') toggleVoice();
    if (e.key === 's' || e.key === 'S') toggleSubtitles();
    if (e.key === 'g' || e.key === 'G') toggleSchema();
    if ((e.key === 'c' || e.key === 'C') && STATE.dom.chatPanel) toggleChat();
    if ((e.key === 'd' || e.key === 'D') && STATE.dom.debugPanel) toggleDebugHud();
    if (e.key === 'Escape') { dismissAtencion(); closeNotes(); closeSummary(); closeChat(); if (STATE.schemaActive) toggleSchema(); }
    showUI();
  });

  document.addEventListener('mousemove', showUI);
  document.addEventListener('click', () => {
    ensureAudioContext();
    showUI();
  });
}

function go(dir) {
  const next = STATE.idx + dir;
  if (next < 0 || next >= STATE.slides.length) return;
  renderSlide(next, dir > 0 ? 'next' : 'prev');
  scheduleHideUI();
}

function toggleNotes() {
  STATE.notesOpen = !STATE.notesOpen;
  document.getElementById('notesPanel').classList.toggle('open', STATE.notesOpen);
}
function closeNotes() {
  STATE.notesOpen = false;
  document.getElementById('notesPanel').classList.remove('open');
}

function toggleFullscreen() {
  if (!document.fullscreenElement) {
    document.documentElement.requestFullscreen().catch(() => {});
  } else {
    document.exitFullscreen().catch(() => {});
  }
}

// ── AUDIO ────────────────────────────────────────────────
function ensureAudioContext() {
  if (!STATE.audioCtx) {
    try {
      STATE.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    } catch {
      return null;
    }
  }
  if (STATE.audioCtx.state === 'suspended') {
    STATE.audioCtx.resume().catch(() => {});
  }
  return STATE.audioCtx;
}

function playChord(freqs) {
  if (!freqs?.length) return;
  const ctx = ensureAudioContext();
  if (!ctx) return;

  const t = ctx.currentTime;
  freqs.forEach((freq) => {
    if (!freq || Number.isNaN(freq) || freq <= 0) return;
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = 'sine';
    osc.frequency.value = freq;
    gain.gain.setValueAtTime(0, t);
    gain.gain.linearRampToValueAtTime(0.08, t + 0.3);
    gain.gain.exponentialRampToValueAtTime(0.001, t + 2.5);
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.start(t);
    osc.stop(t + 2.6);
  });
}

async function ensureMicInput() {
  const ctx = ensureAudioContext();
  if (!ctx) return false;
  if (STATE.analyser && STATE.micStream) return true;

  try {
    const stream = await navigator.mediaDevices.getUserMedia({
      audio: {
        echoCancellation: true,
        noiseSuppression: true,
        autoGainControl: true,
      },
    });
    const source = ctx.createMediaStreamSource(stream);
    const analyser = ctx.createAnalyser();
    analyser.fftSize = 2048;
    analyser.smoothingTimeConstant = 0.82;
    source.connect(analyser);

    STATE.micStream = stream;
    STATE.micSource = source;
    STATE.analyser = analyser;
    STATE.analyserData = new Float32Array(analyser.fftSize);
    STATE.debugMicStatus = 'listo';
    updateDebugHud();
    return true;
  } catch {
    STATE.debugMicStatus = 'no disponible';
    setDebugError('mic_not_available');
    showVoiceFlash('Micrófono no disponible');
    return false;
  }
}

function updateVoiceMetrics() {
  if (!STATE.voiceActive || !STATE.analyser || !STATE.analyserData) {
    STATE.voiceLevel *= 0.9;
    STATE.voicePitch *= 0.9;
    return;
  }

  STATE.analyser.getFloatTimeDomainData(STATE.analyserData);
  let sum = 0;
  for (let i = 0; i < STATE.analyserData.length; i += 1) {
    sum += STATE.analyserData[i] * STATE.analyserData[i];
  }
  const rms = Math.sqrt(sum / STATE.analyserData.length);
  const level = Math.min(1, Math.max(0, (rms - 0.012) * 10));
  STATE.voiceLevel = STATE.voiceLevel * 0.72 + level * 0.28;

  const pitch = detectPitch(STATE.analyserData, ensureAudioContext()?.sampleRate ?? 48000);
  if (pitch > 0) {
    STATE.voicePitch = STATE.voicePitch * 0.75 + pitch * 0.25;
  } else {
    STATE.voicePitch *= 0.92;
  }
}

function detectPitch(buffer, sampleRate) {
  let rms = 0;
  for (let i = 0; i < buffer.length; i += 1) rms += buffer[i] * buffer[i];
  rms = Math.sqrt(rms / buffer.length);
  if (rms < 0.015) return 0;

  let bestOffset = -1;
  let bestCorrelation = 0;
  const minOffset = Math.floor(sampleRate / 900);
  const maxOffset = Math.floor(sampleRate / 80);

  for (let offset = minOffset; offset <= maxOffset; offset += 1) {
    let correlation = 0;
    for (let i = 0; i < buffer.length - offset; i += 1) {
      correlation += 1 - Math.abs(buffer[i] - buffer[i + offset]);
    }
    correlation /= (buffer.length - offset);
    if (correlation > bestCorrelation) {
      bestCorrelation = correlation;
      bestOffset = offset;
    }
  }

  if (bestCorrelation < 0.9 || bestOffset === -1) return 0;
  return sampleRate / bestOffset;
}

function getActiveAccent(slide) {
  if (STATE.reactiveAccent && performance.now() < STATE.reactiveAccentUntil) {
    return STATE.reactiveAccent;
  }
  return slide?.accentColor ?? slide?.accent_color ?? 'primary';
}

const ACCENT_LABELS = { primary: 'IA', alert: 'Alerta', sage: 'Sistema', light: 'Claridad', amber: 'Datos' };

function setReactiveAccent(accent) {
  STATE.reactiveAccent = accent;
  STATE.reactiveAccentUntil = performance.now() + 6000;
  const slide = STATE.slides[STATE.idx];
  const hex = ACCENT_COLORS.find(c => c.id === getActiveAccent(slide))?.hex ?? '#34d399';
  document.documentElement.style.setProperty('--accent', hex);
  // Show flash with the accent color applied
  const flash = STATE.dom.voiceFlash;
  if (flash) {
    flash.style.color = hex;
    flash.style.borderColor = hex;
    showVoiceFlash(`● ${ACCENT_LABELS[accent] ?? accent}`);
    setTimeout(() => { flash.style.color = ''; flash.style.borderColor = ''; }, 2200);
  }
}

// ── VOICE COMMANDS ───────────────────────────────────────
function initVoice() {
  const Recognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!Recognition) {
    STATE.debugSpeechAvailable = false;
    STATE.debugRecognitionStatus = 'speech api no disponible';
    setDebugError('speech_api_unavailable');
    updateDebugHud();
    return;
  }

  STATE.debugSpeechAvailable = true;
  STATE.debugRecognitionStatus = 'lista';
  updateDebugHud();

  const recognition = new Recognition();
  recognition.lang = 'es-MX';
  recognition.continuous = true;
  recognition.interimResults = true;
  recognition.maxAlternatives = 3;

  recognition.onresult = (event) => {
    let interimText = '';
    for (let i = event.resultIndex; i < event.results.length; i += 1) {
      const result = event.results[i];
      if (result.isFinal) {
        const transcript = result[0].transcript.trim();
        const transcripts = [];
        for (let j = 0; j < result.length; j += 1) {
          transcripts.push(result[j].transcript.toLowerCase().trim());
        }
        STATE.debugTranscript = transcript;

        // Check for sudo commands FIRST (even during chat capture)
        const normalized = normalizeSpeechText(transcript);
        const isSudoCmd = /sudo\s*su[mn]\s*(grafo|chat)/.test(normalized) || /su\s*do\s*su[mn]\s*(grafo|chat)/.test(normalized);

        if (isSudoCmd) {
          handleVoiceTranscript(transcripts);
        } else if (STATE.chatVoiceCapture && STATE.chatOpen) {
          // Feed voice into chat input buffer
          STATE.chatVoiceBuffer += (STATE.chatVoiceBuffer ? ' ' : '') + transcript;
          if (STATE.dom.chatInput) STATE.dom.chatInput.value = STATE.chatVoiceBuffer;
          STATE.dom.chatMessages && (STATE.dom.chatMessages.scrollTop = STATE.dom.chatMessages.scrollHeight);
          showVoiceFlash('Chat · ' + (STATE.chatVoiceBuffer.length > 40 ? '...' + STATE.chatVoiceBuffer.slice(-40) : STATE.chatVoiceBuffer));
          // Auto-send after 2.5s silence
          clearTimeout(STATE.chatVoiceSilenceTimer);
          STATE.chatVoiceSilenceTimer = setTimeout(() => {
            if (STATE.chatVoiceCapture && STATE.chatVoiceBuffer.trim()) {
              sendChatMessage();
              STATE.chatVoiceBuffer = '';
              STATE.chatVoiceCapture = false;
              showVoiceFlash('Chat · enviado');
            }
          }, 2500);
        } else {
          handleVoiceTranscript(transcripts);
        }

        updateSubtitle(transcript, false);
        feedSchemaTranscript(transcript);
        STATE.allTranscripts += ' ' + transcript;
        updateDebugHud();
      } else {
        interimText += result[0].transcript;
      }
    }
    if (interimText) {
      if (STATE.chatVoiceCapture && STATE.chatOpen && STATE.dom.chatInput) {
        // Show live interim in the input
        STATE.dom.chatInput.value = STATE.chatVoiceBuffer + (STATE.chatVoiceBuffer ? ' ' : '') + interimText.trim();
      }
      updateSubtitle(interimText.trim(), true);
    }
  };

  recognition.onerror = (event) => {
    if (event.error === 'no-speech' || event.error === 'aborted') return;
    if (event.error === 'not-allowed' || event.error === 'service-not-allowed') {
      STATE.voiceActive = false;
      STATE.debugMicStatus = 'bloqueado';
      STATE.debugRecognitionStatus = 'error';
      updateVoiceButton();
      setDebugError(event.error);
      showVoiceFlash('Micrófono bloqueado');
      return;
    }
    STATE.debugRecognitionStatus = 'error';
    setDebugError(event.error);
    showVoiceFlash(`Voz: ${event.error}`);
  };

  recognition.onend = () => {
    if (!STATE.voiceActive) return;
    const attempts = STATE.voiceRestartAttempts;
    if (attempts > 8) {
      STATE.voiceActive = false;
      STATE.debugVoiceStatus = 'agotada';
      STATE.debugRecognitionStatus = 'detenida';
      updateVoiceButton();
      setDebugError('speech_restart_exhausted');
      showVoiceFlash('Voz: reintentos agotados');
      return;
    }
    const delay = Math.min(100 * Math.pow(2, attempts), 5000);
    STATE.voiceRestartAttempts += 1;
    STATE.debugRecognitionStatus = `reinicio en ${Math.round(delay)}ms`;
    updateDebugHud();
    setTimeout(() => {
      if (!STATE.voiceActive) return;
      try {
        recognition.start();
        STATE.voiceRestartAttempts = Math.max(0, STATE.voiceRestartAttempts - 1);
        STATE.debugRecognitionStatus = 'escuchando';
        updateDebugHud();
      } catch {}
    }, delay);
  };

  STATE.recognition = recognition;
}

async function toggleVoice() {
  if (!STATE.recognition) {
    setDebugError('speech_not_initialized');
    showVoiceFlash('Voz no disponible');
    return;
  }

  ensureAudioContext();
  STATE.voiceActive = !STATE.voiceActive;

  if (STATE.voiceActive) {
    STATE.voiceRestartAttempts = 0;
    STATE.debugVoiceStatus = 'activando';
    STATE.debugRecognitionStatus = 'solicitando audio';
    updateDebugHud();
    const micReady = await ensureMicInput();
    if (!micReady) {
      STATE.voiceActive = false;
      STATE.debugVoiceStatus = 'inactiva';
      updateVoiceButton();
      updateDebugHud();
      return;
    }
    try {
      STATE.recognition.start();
      STATE.debugVoiceStatus = 'activa';
      STATE.debugRecognitionStatus = 'escuchando';
      STATE.debugMicStatus = 'listo';
      updateDebugHud();
      showVoiceFlash('Escuchando');
    } catch {
      STATE.voiceActive = false;
      STATE.debugVoiceStatus = 'inactiva';
      STATE.debugRecognitionStatus = 'error al iniciar';
      setDebugError('speech_start_failed');
      showVoiceFlash('No se pudo iniciar voz');
    }
  } else {
    try {
      STATE.recognition.stop();
    } catch {}
    STATE.debugVoiceStatus = 'inactiva';
    STATE.debugRecognitionStatus = 'detenida';
    updateDebugHud();
    showVoiceFlash('Voz desactivada');
  }

  updateVoiceButton();
}

function updateVoiceButton() {
  STATE.dom.btnVoice?.classList.toggle('voice-active', STATE.voiceActive);
}

function showVoiceFlash(message) {
  const flash = STATE.dom.voiceFlash;
  if (!flash) return;
  flash.textContent = message;
  flash.classList.add('show');
  clearTimeout(STATE.voiceFlashTimer);
  STATE.voiceFlashTimer = setTimeout(() => {
    flash.classList.remove('show');
  }, 1800);
}

function showAtencion() {
  const overlay = STATE.dom.atencionOverlay;
  if (!overlay) return;
  clearTimeout(STATE.atencionTimer);
  overlay.classList.remove('active');
  void overlay.offsetWidth; // force reflow
  overlay.classList.add('active');
  STATE.atencionTimer = setTimeout(() => { overlay.classList.remove('active'); }, 5000);
}
function dismissAtencion() {
  const overlay = STATE.dom.atencionOverlay;
  if (overlay?.classList.contains('active')) {
    clearTimeout(STATE.atencionTimer);
    overlay.classList.remove('active');
  }
}

// ── SUBTITLES ────────────────────────────────────────────
function updateSubtitle(text, isInterim) {
  if (!STATE.subtitlesOn) return;
  const bar = STATE.dom.subtitleBar;
  if (!bar) return;
  clearTimeout(STATE.subtitleTimer);
  if (isInterim) {
    bar.innerHTML = `<span class="interim">${text.replace(/</g, '&lt;')}</span>`;
  } else {
    bar.textContent = text;
    STATE.subtitleTimer = setTimeout(() => { bar.textContent = ''; }, 4000);
  }
  bar.hidden = false;
}

function toggleSubtitles() {
  STATE.subtitlesOn = !STATE.subtitlesOn;
  const bar = STATE.dom.subtitleBar;
  if (!STATE.subtitlesOn) {
    if (bar) { bar.hidden = true; bar.textContent = ''; }
  } else {
    if (bar) bar.hidden = false;
    if (!STATE.voiceActive) toggleVoice();
  }
  updateSubtitleButton();
  showVoiceFlash(STATE.subtitlesOn ? 'Subtítulos ON' : 'Subtítulos OFF');
}

function updateSubtitleButton() {
  STATE.dom.btnSubtitles?.classList.toggle('voice-active', STATE.subtitlesOn);
}

// ── LIVE CONCEPT GRAPH ───────────────────────────────────
// Feed transcript text to the schema — expand words from speech
function feedSchemaTranscript(text) {
  if (!STATE.schemaActive) return;
  const cleaned = String(text ?? '')
    .replace(/\bsudo\s+sum\b/gi, '')
    .replace(/\s+/g, ' ').trim();
  if (!cleaned) return;
  schemaExpandFromSpeech(cleaned);
}

function handleVoiceTranscript(transcripts) {
  const normalizedTranscripts = transcripts
    .map((transcript) => normalizeSpeechText(transcript))
    .filter(Boolean);
  const match = (re) => normalizedTranscripts.some(t => re.test(t));

  // "Sudo sum Grafo" — toggle schema mode
  if (match(/sudo\s*su[mn]\s*grafo/) || match(/su\s*do\s*su[mn]\s*grafo/)) {
    setDebugCommand('sudo_sum_grafo');
    toggleSchema();
    return;
  }

  // "Sudo sum Chat" — toggle AI chat + voice input
  if (match(/sudo\s*su[mn]\s*chat/) || match(/su\s*do\s*su[mn]\s*chat/)) {
    setDebugCommand('sudo_sum_chat');
    toggleChat();
    if (STATE.chatOpen) {
      STATE.chatVoiceCapture = true;
      STATE.chatVoiceBuffer = '';
      showVoiceFlash('Chat · escuchando pregunta...');
    } else {
      STATE.chatVoiceCapture = false;
      STATE.chatVoiceBuffer = '';
      showVoiceFlash('Chat OFF');
    }
    return;
  }

  // "oigan atención" — full-screen yellow overlay for 5 seconds
  if (match(/oigan\s*atenci[oó]n/)) {
    setDebugCommand('oigan_atencion');
    showAtencion();
    return;
  }

  // Color accent from keywords
  for (const rule of VOICE_COLOR_RULES) {
    if (rule.words.some(word => normalizedTranscripts.some(t => t.includes(normalizeSpeechText(word))))) {
      setReactiveAccent(rule.accent);
      break;
    }
  }

  if (match(/siguiente|adelante|avanzar|pr[oó]xim[ao]/)) {
    setDebugCommand('siguiente');
    showVoiceFlash('Siguiente');
    go(1);
    return;
  }

  if (match(/anterior|atr[aá]s|volver|regresar/)) {
    setDebugCommand('anterior');
    showVoiceFlash('Anterior');
    go(-1);
    return;
  }

  if (match(/notas?/)) {
    setDebugCommand('notas');
    showVoiceFlash('Notas');
    toggleNotes();
    return;
  }

  if (match(/pantalla completa|fullscreen/)) {
    setDebugCommand('fullscreen');
    showVoiceFlash('Pantalla completa');
    toggleFullscreen();
    return;
  }

  for (let idx = 0; idx < STATE.slides.length; idx += 1) {
    const words = STATE.slides[idx].commandWords ?? [];
    const hasMatch = words.some((word) => {
      const normalized = normalizeSpeechText(word);
      return normalized && normalizedTranscripts.some((transcript) => transcript.includes(normalized));
    });

    if (!hasMatch) continue;
    setDebugCommand(`slide_${idx + 1}`);
    showVoiceFlash(`Slide ${idx + 1}`);
    renderSlide(idx, idx > STATE.idx ? 'next' : 'prev');
    return;
  }

  setDebugCommand('sin_match');
}

// ── UI HIDE / SHOW ────────────────────────────────────────
function scheduleHideUI() {
  clearTimeout(STATE.uiHideTimer);
  STATE.uiHideTimer = setTimeout(hideUI, 3000);
}
function showUI() {
  STATE.dom.topbar?.classList.remove('hidden');
  STATE.dom.presNav?.classList.remove('hidden');
  STATE.dom.presTimer?.classList.remove('hidden');
  scheduleHideUI();
}
function hideUI() {
  STATE.dom.topbar?.classList.add('hidden');
  STATE.dom.presNav?.classList.add('hidden');
  STATE.dom.presTimer?.classList.add('hidden');
}

// ── TIMER ─────────────────────────────────────────────────
function fmtTime(seconds) {
  const m = Math.floor(seconds / 60);
  const s = Math.floor(seconds % 60);
  return m + ':' + String(s).padStart(2, '0');
}

function updateTimerDisplay(now) {
  if (!STATE.presStartTime) return;
  const d = STATE.dom;
  const slideSec = (now - STATE.slideStartTime) / 1000;
  const totalSec = (now - STATE.presStartTime) / 1000;

  d.timerSlide.textContent = fmtTime(slideSec);
  d.timerTotal.textContent = fmtTime(totalSec);

  // Over-time alert: compare against slide.duracion (minutes)
  const slide = STATE.slides[STATE.idx];
  const durMin = slide?.duracion ?? 0;
  if (durMin > 0 && slideSec > durMin * 60) {
    d.timerSlide.classList.add('timer-over');
  } else {
    d.timerSlide.classList.remove('timer-over');
  }
}

// ── NEXT SLIDE PREVIEW ────────────────────────────────────
function updateNextPreview(idx) {
  const d = STATE.dom;
  const next = STATE.slides[idx + 1];
  if (!next) {
    d.nextPreview.classList.remove('show');
    return;
  }
  d.nextPreviewTitle.textContent = next.titulo ?? '';
  d.nextPreviewTag.textContent = next.tag ?? '';
  d.nextPreview.classList.add('show');
}

// ── AI SUMMARY ────────────────────────────────────────────
async function generateSummary() {
  const overlay = document.getElementById('summaryOverlay');
  const textEl = document.getElementById('summaryText');
  overlay.classList.add('active');
  textEl.textContent = 'Generando resumen con IA...';
  textEl.classList.add('loading');

  const transcript = STATE.allTranscripts.trim();
  if (transcript.length < 50) {
    textEl.textContent = 'No hay suficiente transcripción para generar un resumen.';
    textEl.classList.remove('loading');
    return;
  }

  try {
    const slide = STATE.slides[STATE.idx];
    const res = await fetch('/api/slides/live-graph', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        slide: { titulo: STATE.presentation?.nombre ?? 'Presentación', subtitulo: 'Resumen final' },
        transcript: transcript.slice(-1500),
        existingNodes: [],
      }),
    });
    const data = await res.json();
    if (data.ok && data.graph?.nodes?.length) {
      const concepts = data.graph.nodes.map(n => n.label).join(', ');
      textEl.textContent = `Conceptos clave identificados:\n\n${concepts}\n\nTotal de slides: ${STATE.slides.length}\nTiempo total: ${fmtTime((performance.now() - STATE.presStartTime) / 1000)}`;
    } else {
      textEl.textContent = `Presentación finalizada.\n\nTotal de slides: ${STATE.slides.length}\nTiempo total: ${fmtTime((performance.now() - STATE.presStartTime) / 1000)}`;
    }
    textEl.classList.remove('loading');
  } catch {
    textEl.textContent = `Presentación finalizada.\n\nTotal de slides: ${STATE.slides.length}\nTiempo total: ${fmtTime((performance.now() - STATE.presStartTime) / 1000)}`;
    textEl.classList.remove('loading');
  }
}

function closeSummary() {
  document.getElementById('summaryOverlay').classList.remove('active');
}

// ── AI CHAT ───────────────────────────────────────────────
let _chatAbort = null;

function toggleChat() {
  if (!STATE.dom.chatPanel) return;
  STATE.chatOpen = !STATE.chatOpen;
  STATE.dom.chatPanel.classList.toggle('visible', STATE.chatOpen);
  STATE.dom.btnChat?.classList.toggle('voice-active', STATE.chatOpen);
  if (STATE.chatOpen) STATE.dom.chatInput?.focus();
}

function closeChat() {
  if (!STATE.dom.chatPanel) return;
  STATE.chatOpen = false;
  STATE.chatVoiceCapture = false;
  STATE.chatVoiceBuffer = '';
  clearTimeout(STATE.chatVoiceSilenceTimer);
  STATE.dom.chatPanel.classList.remove('visible');
  STATE.dom.btnChat?.classList.remove('voice-active');
  if (_chatAbort) { _chatAbort.abort(); _chatAbort = null; }
}

async function sendChatMessage() {
  const input = STATE.dom.chatInput;
  const sendBtn = STATE.dom.chatSendBtn;
  if (!input) return;
  const text = input.value.trim();
  if (!text) return;

  input.value = '';
  input.style.height = '';

  // Hide empty placeholder
  const emptyEl = document.getElementById('chatEmpty');
  if (emptyEl) emptyEl.style.display = 'none';

  // Add user bubble
  const userEl = document.createElement('div');
  userEl.className = 'chat-msg user';
  userEl.textContent = text;
  STATE.dom.chatMessages.appendChild(userEl);

  // Add to history
  STATE.chatHistory.push({ role: 'user', content: text });

  // Create streaming assistant bubble
  const asstEl = document.createElement('div');
  asstEl.className = 'chat-msg assistant streaming';
  STATE.dom.chatMessages.appendChild(asstEl);
  STATE.dom.chatMessages.scrollTop = STATE.dom.chatMessages.scrollHeight;

  if (sendBtn) sendBtn.disabled = true;

  const slide = STATE.slides[STATE.idx] ?? {};
  const context = {
    slideTitle: slide.titulo ?? '',
    slideSubtitulo: slide.subtitulo ?? '',
    conceptosClave: slide.conceptosClave ?? slide.conceptos_clave ?? [],
    presentationName: STATE.presentation?.nombre ?? '',
  };

  try {
    _chatAbort = new AbortController();
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mode: 'presenter', messages: STATE.chatHistory.slice(-10), context }),
      signal: _chatAbort.signal,
    });

    if (!res.ok) {
      asstEl.classList.remove('streaming');
      asstEl.textContent = `Error ${res.status}: no se pudo conectar al asistente.`;
      return;
    }

    let accumulated = '';
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop() ?? '';
      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        const payload = line.slice(6).trim();
        if (payload === '[DONE]') break;
        try {
          const token = JSON.parse(payload).response ?? '';
          accumulated += token;
          asstEl.textContent = accumulated;
          STATE.dom.chatMessages.scrollTop = STATE.dom.chatMessages.scrollHeight;
        } catch { /* malformed chunk, skip */ }
      }
    }

    asstEl.classList.remove('streaming');

    // If schema overlay is active, parse ESQUEMA: pattern and inject nodes
    const schemaMatch = accumulated.match(/ESQUEMA:\s*([^\n\u2192\-]+?)\s*(?:\u2192|->)\s*([^\n]+)/i);
    if (schemaMatch && STATE.schemaActive) {
      const root = schemaMatch[1].trim().split(/[\s_]+/).slice(0, 3).join(' ');
      const branches = schemaMatch[2].split(',').map(s => s.trim()).filter(Boolean).slice(0, 5);
      const cx = window.innerWidth * 0.5;
      const cy = window.innerHeight * 0.42;
      const rootId = `chat-root-${Date.now()}`;
      schemaAddWord(rootId, root, cx, cy, 'root', null);
      branches.forEach((b, i) => {
        const angle = (i / branches.length) * Math.PI * 2 - Math.PI / 2;
        const bx = cx + Math.cos(angle) * window.innerWidth * 0.22;
        const by = cy + Math.sin(angle) * window.innerHeight * 0.18;
        const bid = `chat-b-${Date.now()}-${i}`;
        schemaAddWord(bid, b, bx, by, 'branch', rootId);
        schemaAddLine(rootId, bid);
      });
    }

    // Persist to history (cap at 20 turns)
    STATE.chatHistory.push({ role: 'assistant', content: accumulated });
    if (STATE.chatHistory.length > 20) STATE.chatHistory.splice(0, STATE.chatHistory.length - 20);

  } catch (err) {
    if (err?.name !== 'AbortError') {
      asstEl.classList.remove('streaming');
      asstEl.textContent = 'Error de conexión. Verifica que el servidor esté activo.';
    } else {
      asstEl.remove();
    }
  } finally {
    if (sendBtn) sendBtn.disabled = false;
    _chatAbort = null;
  }
}

// ── PARTICLE ENGINE ───────────────────────────────────────
function resizeCanvas() {
  const c = STATE.canvas;
  if (!c) return;
  c.width = window.innerWidth;
  c.height = window.innerHeight;
}

function initParticles() {
  STATE.particles = Array.from({ length: PARTICLE_COUNT }, () => ({
    x: Math.random(), y: Math.random(),
    vx: (Math.random() - 0.5) * 0.002,
    vy: (Math.random() - 0.5) * 0.002,
    size: 1 + Math.random() * 2,
  }));
}

function startLoop() {
  STATE.lastFrameTime = performance.now();
  function frame() {
    const now = performance.now();
    const dt = (now - STATE.lastFrameTime) / 1000;
    STATE.lastFrameTime = now;
    STATE.animTime += dt;
    updateVoiceMetrics();
    drawParticles();
    if (STATE.schemaActive && STATE.schemaWords.size > 1) schemaNudge();
    updateTimerDisplay(now);
    STATE.animFrame = requestAnimationFrame(frame);
  }
  if (STATE.animFrame) cancelAnimationFrame(STATE.animFrame);
  frame();
}

function drawParticles() {
  const { ctx, canvas, particles, animTime } = STATE;
  if (!ctx) return;
  const w = canvas.width, h = canvas.height;
  const slide = STATE.slides[STATE.idx];
  const state   = slide?.particleState ?? slide?.particle_state ?? 'chaos';
  const level = STATE.voiceLevel;
  const pitch = STATE.voicePitch;
  const pitchNorm = pitch ? Math.min(1, Math.max(0, (pitch - 120) / 720)) : 0;
  const speed   = (slide?.particleSpeed ?? slide?.particle_speed ?? 0.04) * (1 + level * 2.2);
  const colorId = getActiveAccent(slide);
  const color   = ACCENT_COLORS.find(c => c.id === colorId)?.hex ?? '#34d399';

  const isLight = document.documentElement.getAttribute('data-theme') === 'light';
  const trailAlpha = Math.max(0.06, 0.16 - level * 0.08);
  ctx.fillStyle = isLight ? `rgba(240,242,245,${trailAlpha})` : `rgba(13,17,23,${trailAlpha})`;
  ctx.fillRect(0, 0, w, h);

  particles.forEach((p, i) => {
    applyState(p, i, state, speed, animTime, w, h);
    const tremor = level * 0.0025;
    p.vx += (Math.random() - 0.5) * tremor * (1 + pitchNorm * 2);
    p.vy += (Math.random() - 0.5) * tremor * (0.6 + pitchNorm * 1.8);
    p.x += p.vx; p.y += p.vy;
    if (p.x < 0) p.x = 1; if (p.x > 1) p.x = 0;
    if (p.y < 0) p.y = 1; if (p.y > 1) p.y = 0;
    const alpha = 0.28 + Math.sin(animTime * (2 + level * 6) + i) * 0.18 + level * 0.32;
    ctx.fillStyle = color + Math.round(alpha * 255).toString(16).padStart(2,'0');
    ctx.beginPath();
    ctx.arc(p.x * w, p.y * h, p.size * (1 + level * 1.9 + pitchNorm * 0.8), 0, Math.PI * 2);
    ctx.fill();
  });
}

function applyState(p, i, state, speed, t, w, h) {
  const s = speed * 0.5;
  switch (state) {
    case 'chaos':
      p.vx += (Math.random()-0.5)*s; p.vy += (Math.random()-0.5)*s;
      p.vx *= 0.98; p.vy *= 0.98; break;
    case 'flow':
      p.vx += Math.sin(p.y*6+t)*s*0.5; p.vy += 0.0002;
      p.vx *= 0.99; p.vy *= 0.99; break;
    case 'cluster': {
      const cx=0.3+(i%3)*0.2, cy=0.3+Math.floor((i%9)/3)*0.2;
      p.vx+=(cx-p.x)*s*0.1; p.vy+=(cy-p.y)*s*0.1;
      p.vx*=0.97; p.vy*=0.97; break; }
    case 'network': {
      const nx=(i%8)/8+0.06, ny=Math.floor(i/8)/(PARTICLE_COUNT/8)+0.06;
      p.vx+=(nx-p.x)*s*0.05; p.vy+=(ny-p.y)*s*0.05;
      p.vx+=Math.sin(t+i)*s*0.02; p.vy+=Math.cos(t+i)*s*0.02;
      p.vx*=0.96; p.vy*=0.96; break; }
    case 'helix': {
      const a=(i/PARTICLE_COUNT)*Math.PI*4+t;
      p.vx+=(0.5+Math.cos(a)*0.25-p.x)*s*0.08;
      p.vy+=((i/PARTICLE_COUNT)-p.y)*s*0.08;
      p.vx*=0.96; p.vy*=0.96; break; }
    case 'grid': {
      const cols=20, gx=((i%cols)+0.5)/cols, gy=(Math.floor(i/cols)+0.5)/(PARTICLE_COUNT/cols);
      p.vx+=(gx-p.x)*s*0.1; p.vy+=(gy-p.y)*s*0.1;
      p.vx*=0.95; p.vy*=0.95; break; }
    case 'pulse': {
      const a=Math.atan2(p.y-0.5,p.x-0.5), r=0.15+Math.sin(t*2)*0.1;
      p.vx+=(0.5+Math.cos(a)*r-p.x)*s*0.08;
      p.vy+=(0.5+Math.sin(a)*r-p.y)*s*0.08;
      p.vx*=0.96; p.vy*=0.96; break; }
    case 'orbit': {
      const oa=(i/PARTICLE_COUNT)*Math.PI*2+t*(0.5+(i%3)*0.2), or=0.1+(i%5)*0.06;
      p.vx+=(0.5+Math.cos(oa)*or-p.x)*s*0.1;
      p.vy+=(0.5+Math.sin(oa)*or-p.y)*s*0.1;
      p.vx*=0.96; p.vy*=0.96; break; }
    case 'collapse':
      p.vx+=(0.5-p.x)*s*0.05; p.vy+=(0.5-p.y)*s*0.05;
      p.vx*=0.98; p.vy*=0.98; break;
    case 'expand':
      p.vx+=(p.x-0.5)*s*0.02; p.vy+=(p.y-0.5)*s*0.02;
      p.vx*=0.99; p.vy*=0.99; break;
  }
}

init();
  </script>

  transition: color 0.15s, border-color 0.15s, background 0.15s;
}
.chapter-nav-btn:hover {
  color: var(--color-text-primary);
  border-color: rgba(255,255,255,0.2);
  background: var(--color-surface);
}
.chapter-nav-prev.hidden, .chapter-nav-next.hidden {
  visibility: hidden;
}

/* ═══════════════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════════════ */

/* Sidenotes fold into body on narrower screens */
@media (max-width: 1200px) {
  .sidenote {
    float: none;
    width: 100%;
    max-width: 600px;
    margin: 1rem 0;
    padding: 0.75rem 1rem;
    border-left: 2px solid var(--color-border);
    background: var(--color-surface);
    border-radius: 0 4px 4px 0;
  }
}

@media (max-width: 900px) {
  .libro-layout { grid-template-columns: 1fr; }

  .libro-toc {
    position: fixed; top: 0; left: 0; bottom: 0;
    width: 280px;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
    box-shadow: 4px 0 24px rgba(0,0,0,0.3);
  }
  .libro-toc.open { transform: translateX(0); }

  .toc-toggle { display: flex; }

  .chapter { padding: 3rem 1.5rem; }
  .chapter-nav { padding: 2rem 1.5rem 4rem; }

  .profiles-grid { grid-template-columns: 1fr; }
  .stats-row { grid-template-columns: 1fr; }
  .stat-card { border-right: none; border-bottom: 1px solid var(--color-border); }
  .stat-card:last-child { border-bottom: none; }
}

@media (max-width: 520px) {
  .chapter-title { font-size: 1.6rem; }
  .chapter-body { font-size: 0.95rem; }
  .chapter-lead { font-size: 1.05rem; }
  .chapter-quote p { font-size: 1rem; }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .libro-progress-fill { transition: none; }
  .libro-toc { transition: none; }
  .toc-link { transition: none; }
  .chapter-nav-btn { transition: none; }
}
</style>

<script is:inline>
(function() {
  const chapters = document.querySelectorAll('.chapter');
  const tocLinks = document.querySelectorAll('.toc-link');
  const progressFill = document.getElementById('libroProgressFill');
  const main = document.getElementById('libroMain');
  const toc = document.getElementById('libroToc');
  const tocToggle = document.getElementById('tocToggle');
  const navPrev = document.getElementById('navPrev');
  const navNext = document.getElementById('navNext');
  const navPrevLabel = document.getElementById('navPrevLabel');
  const navNextLabel = document.getElementById('navNextLabel');

  const chapterIds = [...chapters].map(c => c.id);
  let activeChapter = chapterIds[0];

  // ── Reading progress ──────────────────────────────────
  function updateProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
    progressFill.style.width = progress + '%';
  }

  // ── TOC active highlighting ───────────────────────────
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        activeChapter = entry.target.id;
        tocLinks.forEach(link => {
          link.classList.toggle('active', link.dataset.chapter === activeChapter);
        });
        updateChapterNav();

        // Scroll active TOC link into view within sidebar
        const activeLink = toc.querySelector('.toc-link.active');
        if (activeLink) {
          activeLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
      }
    });
  }, {
    rootMargin: '-20% 0px -60% 0px',
    threshold: 0,
  });

  chapters.forEach(ch => observer.observe(ch));

  // ── Chapter navigation ────────────────────────────────
  function updateChapterNav() {
    const idx = chapterIds.indexOf(activeChapter);
    if (idx > 0) {
      navPrev.href = '#' + chapterIds[idx - 1];
      navPrevLabel.textContent = chapters[idx - 1].querySelector('.chapter-title')?.textContent ?? 'Anterior';
      navPrev.classList.remove('hidden');
    } else {
      navPrev.classList.add('hidden');
    }
    if (idx < chapterIds.length - 1) {
      navNext.href = '#' + chapterIds[idx + 1];
      navNextLabel.textContent = chapters[idx + 1].querySelector('.chapter-title')?.textContent ?? 'Siguiente';
      navNext.classList.remove('hidden');
    } else {
      navNext.classList.add('hidden');
    }
  }

  // ── TOC smooth scroll ─────────────────────────────────
  tocLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.getElementById(link.dataset.chapter);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        // Close mobile TOC
        toc.classList.remove('open');
      }
    });
  });

  // ── Mobile TOC toggle ─────────────────────────────────
  tocToggle.addEventListener('click', () => {
    toc.classList.toggle('open');
  });

  // Close TOC on outside click (mobile)
  document.addEventListener('click', (e) => {
    if (toc.classList.contains('open') && !toc.contains(e.target) && e.target !== tocToggle) {
      toc.classList.remove('open');
    }
  });

  // ── Keyboard navigation ───────────────────────────────
  document.addEventListener('keydown', (e) => {
    // Don't intercept when typing in inputs
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

    const idx = chapterIds.indexOf(activeChapter);
    if ((e.key === 'ArrowLeft' || e.key === 'PageUp') && idx > 0) {
      e.preventDefault();
      document.getElementById(chapterIds[idx - 1])?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    if ((e.key === 'ArrowRight' || e.key === 'PageDown') && idx < chapterIds.length - 1) {
      e.preventDefault();
      document.getElementById(chapterIds[idx + 1])?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // ── Sidenote scroll-to on ref click ───────────────────
  document.querySelectorAll('.ref-link').forEach(link => {
    link.addEventListener('click', (e) => {
      // On wide screens, sidenotes are visible in margin — just highlight
      const target = document.querySelector(link.getAttribute('href'));
      if (!target) return;
      if (window.innerWidth > 1200) {
        e.preventDefault();
        target.style.background = 'rgba(96,165,250,0.12)';
        setTimeout(() => { target.style.background = ''; }, 2000);
      }
      // On narrow screens, let default anchor behavior scroll to it
    });
  });

  // ── Scroll listener ───────────────────────────────────
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => { updateProgress(); ticking = false; });
      ticking = true;
    }
  }, { passive: true });

  // Init
  updateProgress();
  updateChapterNav();

  // Set first TOC link active
  tocLinks[0]?.classList.add('active');
})();
</script>
